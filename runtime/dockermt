runtime_open() {
  _print_cli_banner
  local requested_target=""
  local want_no_open=0
  local explicit_url=""
  local launch_display=""
  local x410_reason=""
  local forwarded=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --target)
        shift || true
        requested_target="${1:-}"
        ;;
      --target=*)
        requested_target="${1#--target=}"
        ;;
      --no-open)
        want_no_open=1
        forwarded+=("--no-open")
        ;;
      --url)
        shift || true
        explicit_url="${1:-}"
        forwarded+=("--url" "${explicit_url}")
        ;;
      --url=*)
        explicit_url="${1#--url=}"
        forwarded+=("--url=${explicit_url}")
        ;;
      --app|--build|--start)
        ;;
      *)
        if [ -z "$requested_target" ]; then
          requested_target="$1"
        else
          echo "ERR: argumento inesperado em 'dockermt container open': $1" >&2
          return 1
        fi
        ;;
    esac
    shift || true
  done
  local runtime_name current_name
  runtime_name="$(normalize_runtime_target "$requested_target")"
  current_name="$(resolve_current_runtime_container)"
  if [ "${ROUTED_EXPLICIT_TARGET:-0}" != "1" ] && runtime_is_instance "$current_name"; then
    local short_current
    short_current="$(runtime_short_name "$current_name")"
    echo "ERR: 'dockermt container open' dentro da instancia exige alvo explicito com @." >&2
    echo "Use: dockermt @${short_current} container open" >&2
    return 1
  fi
  if [ "$runtime_name" != "$current_name" ]; then
    if ! container_exists "$runtime_name"; then
      echo "ERR: runtime nao localizado: $runtime_name" >&2
      return 1
    fi
    docker exec "$runtime_name" /usr/local/bin/dockermt container open "${forwarded[@]}"
    return $?
  fi
  local url
  url="${explicit_url:-$(runtime_web_url "$runtime_name")}"
  printf 'container: ativo
'
  printf 'url: %s
' "$url"
  if [ "$want_no_open" = "1" ]; then
    return 0
  fi
  if ! launch_display="$(runtime_external_display 2>/dev/null)"; then
    x410_reason="DOCKERMT_APP_DISPLAY ausente no host"
    printf 'mt5: falha no X410.
'
    printf 'mt5-display: nao informado
'
    printf 'mt5-defeito: %s
' "$x410_reason"
    printf 'mt5-hint: este runtime nao usa fallback de browser.
'
    return 1
  fi
  if runtime_open_mt5_on_display "$launch_display"; then
    printf 'mt5: aberto no display externo.
'
    printf 'mt5-display: %s
' "$launch_display"
    return 0
  fi
  x410_reason="${RUNTIME_MT5_OPEN_REASON:-falha ao abrir MT5 no display externo}"
  printf 'mt5: falha no X410.
'
  printf 'mt5-display: %s
' "$launch_display"
  printf 'mt5-defeito: %s
' "$x410_reason"
  printf 'mt5-hint: este runtime nao usa fallback de browser.
'
  return 1
}

instance_container_name_from_slug() {
  printf 'dockermt-%s\n' "$1"
}

instance_volume_name_from_slug() {
  printf 'dockermt.instance.%s\n' "$1"
}

instance_state_volume_from_slug() {
  printf 'dockermt_state.%s\n' "$1"
}

port_is_free() {
  local host_port="${1:-}"
  [ -n "$host_port" ] || return 1
  if docker ps --format '{{.Ports}}' | grep -Eq "(^|[, ])(0\\.0\\.0\\.0|\\[::\\]):${host_port}->"; then
    return 1
  fi
  return 0
}

allocate_instance_ports() {
  local offset=1
  while [ "$offset" -le 200 ]; do
    local telnet_port web_port py_port
    telnet_port="$((1122 + offset))"
    web_port="$((3000 + offset))"
    py_port="$((8001 + offset))"
    if port_is_free "$telnet_port" && port_is_free "$web_port" && port_is_free "$py_port"; then
      printf '%s|%s|%s\n' "$telnet_port" "$web_port" "$py_port"
      return 0
    fi
    offset="$((offset + 1))"
  done
  return 1
}

clone_volume_contents() {
  local source_volume="${1:-}"
  local target_volume="${2:-}"
  [ -n "$source_volume" ] || return 1
  [ -n "$target_volume" ] || return 1
  docker run --rm -v "${source_volume}:/from:ro" -v "${target_volume}:/to" alpine sh -lc \
    'cd /from && tar cf - . | (cd /to && tar xf -)'
}

replace_volume_contents() {
  local source_volume="${1:-}"
  local target_volume="${2:-}"
  [ -n "$source_volume" ] || return 1
  [ -n "$target_volume" ] || return 1
  docker volume inspect "$target_volume" >/dev/null 2>&1 || docker volume create "$target_volume" >/dev/null
  docker run --rm -v "${source_volume}:/from:ro" -v "${target_volume}:/to" alpine sh -lc \
    'find /to -mindepth 1 -maxdepth 1 -exec rm -rf {} +;
     cd /from &&
     tar \
       --exclude=./.XDG \
       --exclude=./.dockermt/codex \
       --exclude=./.dockermt/docs \
       --exclude=./.dockermt/extensions \
       -cf - . | (cd /to && tar xf -)'
}

random_instance_theme_pair() {
  local -a themes=(
    "blue:white"
    "cyan:black"
    "green:black"
    "magenta:white"
    "red:white"
    "yellow:black"
    "gray:black"
  )
  local raw idx
  raw="$(od -An -N2 -tu2 /dev/urandom 2>/dev/null | tr -d ' ' || true)"
  if ! printf '%s' "$raw" | grep -Eq '^[0-9]+$'; then
    raw="$(date +%s)"
  fi
  idx=$((raw % ${#themes[@]}))
  printf '%s\n' "${themes[$idx]}"
}

auto_instance_banner_color() {
