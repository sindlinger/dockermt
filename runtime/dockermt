require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "ERR: docker CLI nao encontrado no container." >&2
    exit 127
  fi
  if [ ! -S "$DOCKER_SOCKET_PATH" ]; then
    echo "ERR: docker socket nao esta montado em '$DOCKER_SOCKET_PATH'." >&2
    exit 127
  fi
}

resolve_current_runtime_container() {
  if [ -n "${DOCKERMT_CONTAINER_NAME:-}" ]; then
    printf '%s\n' "$DOCKERMT_CONTAINER_NAME"
    return 0
  fi
  if command -v docker >/dev/null 2>&1 && [ -S "$DOCKER_SOCKET_PATH" ]; then
    local resolved_name
    resolved_name="$(docker inspect "$HOSTNAME" --format '{{.Name}}' 2>/dev/null | sed 's#^/##')"
    if [ -n "$resolved_name" ]; then
      printf '%s\n' "$resolved_name"
      return 0
    fi
  fi
  printf '%s\n' "$DEFAULT_CONTAINER_FALLBACK"
}

runtime_container_label() {
  local container_name="${1:-}"
  local key="${2:-}"
  local value=""
  [ -n "$container_name" ] || return 0
  [ -n "$key" ] || return 0
  if command -v docker >/dev/null 2>&1 && [ -S "$DOCKER_SOCKET_PATH" ]; then
    value="$(docker inspect "$container_name" --format "{{index .Config.Labels \"$key\"}}" 2>/dev/null || true)"
    case "$value" in
      "<no value>"|"")
        value=""
        ;;
    esac
  fi
  printf '%s\n' "$value"
}

runtime_parent_container() {
  local container_name="${1:-}"
  [ -n "$container_name" ] || container_name="$(resolve_current_runtime_container)"
  runtime_container_label "$container_name" "dockermt.runtime.parent"
}

runtime_is_instance() {
  local container_name="${1:-}"
  local marker short_name env_instance
  [ -n "$container_name" ] || container_name="$(resolve_current_runtime_container)"
  marker="$(runtime_container_label "$container_name" "dockermt.runtime")"
  if [ "$marker" = "1" ]; then
    return 0
  fi
  env_instance="$(sanitize_snapshot_name "${DOCKERMT_INSTANCE_NAME:-}")"
  if [ -n "$env_instance" ]; then
    short_name="$(runtime_short_name "$container_name")"
    if [ "$short_name" = "$env_instance" ]; then
      return 0
    fi
  fi
  return 1
}

runtime_short_name() {
  local container_name="${1:-}"
  [ -n "$container_name" ] || container_name="$(resolve_current_runtime_container)"
  case "$container_name" in
    dockermt-*)
      printf '%s\n' "${container_name#dockermt-}"
      ;;
    *)
      printf '%s\n' "$container_name"
      ;;
  esac
}

resolve_central_runtime_container() {
  local current_name parent_name candidate
  current_name="$(resolve_current_runtime_container)"
  parent_name="$(runtime_parent_container "$current_name")"
  if [ -n "$parent_name" ] && container_exists "$parent_name"; then
    printf '%s\n' "$parent_name"
    return 0
  fi
  candidate="$(docker ps --filter 'label=dockermt.role=central' --format '{{.Names}}' 2>/dev/null | head -n 1)"
  if [ -n "$candidate" ] && container_exists "$candidate"; then
    printf '%s\n' "$candidate"
    return 0
  fi
  candidate="$(docker ps --filter 'label=dockermt.central=1' --format '{{.Names}}' 2>/dev/null | head -n 1)"
  if [ -n "$candidate" ] && container_exists "$candidate"; then
    printf '%s\n' "$candidate"
    return 0
  fi
  printf '%s\n' "$current_name"
}

normalize_runtime_target() {
  local raw="${1:-}" safe="" candidate="" current_name="" current_short=""
  if [ -z "$raw" ]; then
    resolve_current_runtime_container
    return 0
  fi
  case "$raw" in
    @*)
      raw="${raw#@}"
      ;;
  esac
  current_name="$(resolve_current_runtime_container)"
  safe="$(sanitize_snapshot_name "$raw")"
  current_short="$(runtime_short_name "$current_name")"
  if [ "$raw" = "$current_name" ] || { [ -n "$safe" ] && [ "$safe" = "$current_short" ]; }; then
    printf '%s\n' "$current_name"
    return 0
  fi
  if [ "$raw" = "central" ]; then
    resolve_central_runtime_container
    return 0
  fi
  if docker inspect "$raw" >/dev/null 2>&1; then
    printf '%s\n' "$raw"
    return 0
  fi
  if [ -n "$safe" ]; then
    candidate="$(docker ps -a --filter "label=dockermt.role=instance" --filter "label=dockermt.instance.name=${safe}" --format '{{.Names}}' 2>/dev/null | head -n 1 || true)"
    if [ -n "$candidate" ] && docker inspect "$candidate" >/dev/null 2>&1; then
      printf '%s\n' "$candidate"
      return 0
    fi
    candidate="$(docker ps -a --filter "label=dockermt.runtime=1" --filter "label=dockermt.runtime.name=${safe}" --format '{{.Names}}' 2>/dev/null | head -n 1 || true)"
    if [ -n "$candidate" ] && docker inspect "$candidate" >/dev/null 2>&1; then
      printf '%s\n' "$candidate"
      return 0
    fi
    if docker inspect "dockermt-${safe}" >/dev/null 2>&1; then
      printf 'dockermt-%s\n' "$safe"
      return 0
    fi
  fi
  printf '%s\n' "$raw"
}

container_exists() {
  local container_name="${1:-}"
  local current_name=""
  [ -n "$container_name" ] || return 1
  current_name="$(resolve_current_runtime_container)"
  if [ "$container_name" = "$current_name" ]; then
    return 0
  fi
  docker inspect "$container_name" >/dev/null 2>&1
}

container_host_port() {
  local container_name="${1:-}"
  local container_port="${2:-}"
  local fallback="${3:-}"
  local host_port=""
  local current_name=""
  current_name="$(resolve_current_runtime_container)"
  if [ -n "$container_name" ] && [ "$container_name" = "$current_name" ]; then
    case "$container_port" in
      3000)
        if [ -n "${DOCKERMT_HOST_WEB_PORT:-}" ]; then
          printf '%s\n' "$DOCKERMT_HOST_WEB_PORT"
          return 0
        fi
        ;;
      1122)
        if [ -n "${DOCKERMT_HOST_TELNET_PORT:-}" ]; then
          printf '%s\n' "$DOCKERMT_HOST_TELNET_PORT"
          return 0
        fi
        ;;
      8001)
        if [ -n "${DOCKERMT_HOST_PY_PORT:-}" ]; then
          printf '%s\n' "$DOCKERMT_HOST_PY_PORT"
          return 0
        fi
        ;;
    esac
  fi
  if [ -n "$container_name" ] && [ -n "$container_port" ]; then
    host_port="$(docker inspect "$container_name" --format "{{with index .NetworkSettings.Ports \"${container_port}/tcp\"}}{{(index . 0).HostPort}}{{end}}" 2>/dev/null || true)"
  fi
  if [ -n "$host_port" ]; then
    printf '%s\n' "$host_port"
  else
    printf '%s\n' "$fallback"
  fi
}

container_env_value() {
  local container_name="${1:-}"
  local env_key="${2:-}"
  [ -n "$container_name" ] || return 0
  [ -n "$env_key" ] || return 0
  docker inspect "$container_name" --format '{{range .Config.Env}}{{println .}}{{end}}' 2>/dev/null \
    | sed -n "s/^${env_key}=//p" \
    | tail -n 1
}

migrate_instance_workspace_dirs_in_volume() {
  local target_volume="${1:-}"
  local old_slug="${2:-}"
  local new_slug="${3:-}"
  [ -n "$target_volume" ] || return 1
  [ -n "$old_slug" ] || return 1
  [ -n "$new_slug" ] || return 1
  [ "$old_slug" != "$new_slug" ] || return 0
  docker run --rm \
    -e "MQL5_ROOT_REL=${DOCKERMT_MQL5_ROOT_REL}" \
    -e "OLD_SLUG=${old_slug}" \
    -e "NEW_SLUG=${new_slug}" \
    -e "RUNTIME_UID=${DOCKERMT_RUNTIME_UID}" \
    -e "RUNTIME_GID=${DOCKERMT_RUNTIME_GID}" \
    -v "${target_volume}:/config" \
    alpine sh -lc '
      set -eu
      root="/config/${MQL5_ROOT_REL}"
      for category in Files Experts Indicators Services Include Scripts Libraries; do
        base="$root/$category"
        src="$base/$OLD_SLUG"
        dst="$base/$NEW_SLUG"
        mkdir -p "$base"
        if [ -e "$src" ]; then
          if [ -e "$dst" ]; then
            cd "$src" && tar cf - . | (cd "$dst" && tar xf -)
            rm -rf "$src"
          else
            mv "$src" "$dst"
          fi
        else
          mkdir -p "$dst"
        fi
      done
      chown -R "${RUNTIME_UID}:${RUNTIME_GID}" \
        "$root/Files" "$root/Experts" "$root/Indicators" "$root/Include" "$root/Scripts" "$root/Libraries" 2>/dev/null || true
      chown -R 0:0 "$root/Services" 2>/dev/null || true
    '
}

runtime_instance_rename_apply() {
  require_docker
  local old_ref="${1:-}"
  local new_raw="${2:-}"
  [ -n "$old_ref" ] || { echo "ERR: uso interno: dockermt _instance-rename <instancia-atual> <novo-nome>" >&2; return 1; }
  [ -n "$new_raw" ] || { echo "ERR: uso interno: dockermt _instance-rename <instancia-atual> <novo-nome>" >&2; return 1; }

  local old_container old_short new_short new_container
  local image config_volume state_volume parent_container old_user
  local telnet_port web_port py_port runtime_status
  local -a runtime_user_args=()
  local runtime_src_dockermt runtime_src_shell runtime_src_args runtime_src_dispatch

  old_container="$(normalize_runtime_target "$old_ref")"
  container_exists "$old_container" || { echo "ERR: instancia nao localizada: $old_ref" >&2; return 1; }
  runtime_is_instance "$old_container" || { echo "ERR: alvo nao e instancia DockerMT: $old_container" >&2; return 1; }

  old_short="$(runtime_short_name "$old_container")"
  new_short="$(sanitize_snapshot_name "$new_raw")"
  [ -n "$new_short" ] || { echo "ERR: novo nome invalido." >&2; return 1; }
  if [ "$new_short" = "$old_short" ]; then
    echo "[dockermt] rename sem alteracao: ${old_short}"
    return 0
  fi

  new_container="$(instance_container_name_from_slug "$new_short")"
  if container_exists "$new_container"; then
    echo "ERR: ja existe uma instancia com este nome: $new_short" >&2
    return 1
  fi

  image="$(current_container_image "$old_container")"
  old_user="$(docker inspect "$old_container" --format '{{.Config.User}}' 2>/dev/null || true)"
  config_volume="$(current_container_config_volume "$old_container")"
  state_volume="$(container_env_value "$old_container" "DOCKERMT_STATE_VOLUME")"
  parent_container="$(runtime_parent_container "$old_container")"
  telnet_port="$(container_host_port "$old_container" "1122" "")"
  web_port="$(container_host_port "$old_container" "3000" "")"
  py_port="$(container_host_port "$old_container" "8001" "")"
  runtime_status="$(current_container_status "$old_container")"

  [ -n "$image" ] || { echo "ERR: nao foi possivel identificar a imagem da instancia atual." >&2; return 1; }
  [ -n "$config_volume" ] || { echo "ERR: nao foi possivel identificar o volume /config da instancia atual." >&2; return 1; }
  [ -n "$state_volume" ] || state_volume="$(instance_state_volume_from_slug "$old_short")"
  [ -n "$parent_container" ] || parent_container="$(resolve_current_runtime_container)"
  [ -n "$telnet_port" ] || { echo "ERR: porta host Telnet da instancia atual nao encontrada." >&2; return 1; }
  [ -n "$web_port" ] || { echo "ERR: porta host Web da instancia atual nao encontrada." >&2; return 1; }
  [ -n "$py_port" ] || { echo "ERR: porta host Python da instancia atual nao encontrada." >&2; return 1; }
  if [ -n "$old_user" ]; then
    runtime_user_args=(--user "$old_user")
  fi

  echo "[dockermt] rename: ${old_short} -> ${new_short}"
  if [ "$runtime_status" = "running" ]; then
    echo "[dockermt] parando instancia atual..."
    docker stop "$old_container" >/dev/null
  fi

  echo "[dockermt] migrando diretorios da instancia..."
  migrate_instance_workspace_dirs_in_volume "$config_volume" "$old_short" "$new_short"
  prepare_codex_layout_in_volume "$config_volume" "$new_short" reuse

  echo "[dockermt] criando container renomeado..."
  if ! docker run -d \
    --name "$new_container" \
    --hostname "$new_container" \
    --gpus all \
    "${runtime_user_args[@]}" \
    -e "TITLE=DockerMT [$new_short]" \
    -e "DOCKERMT_CONTAINER_NAME=$new_container" \
    -e "DOCKERMT_INSTANCE_NAME=$new_short" \
    -e "DOCKERMT_STATE_VOLUME=$state_volume" \
    -e "TELNETMT_PORT=1122" \
    -e "MT5_WEB_PORT=3000" \
    -e "MT5_PY_PORT=8001" \
    -e "DOCKERMT_HOST_TELNET_PORT=$telnet_port" \
    -e "DOCKERMT_HOST_WEB_PORT=$web_port" \
    -e "DOCKERMT_HOST_PY_PORT=$py_port" \
    -e "DOCKERMT_SNAPSHOT_REPO=$SNAPSHOT_REPO" \
    -e "DOCKERMT_SNAPSHOT_VOLUME_PREFIX=$SNAPSHOT_VOLUME_PREFIX" \
    -e "DOCKERMT_PULL_REPO=$PULL_REPO" \
    -e "DOCKERMT_DOCKER_SOCKET_PATH=$DOCKER_SOCKET_PATH" \
    -v "${config_volume}:/config" \
    -v "${DOCKER_SOCKET_PATH}:${DOCKER_SOCKET_PATH}" \
    -p "${telnet_port}:1122" \
    -p "${web_port}:3000" \
    -p "${py_port}:8001" \
    --label "dockermt.role=instance" \
    --label "dockermt.instance.name=$new_short" \
    --label "dockermt.node.role=instance" \
    --label "dockermt.node.name=$new_short" \
    --label "dockermt.node.parent=$parent_container" \
    --label "dockermt.runtime=1" \
    --label "dockermt.runtime.name=$new_short" \
    --label "dockermt.runtime.parent=$parent_container" \
    --label "dockermt.runtime.config-volume=$config_volume" \
    "$image" >/dev/null; then
    echo "ERR: falha ao criar container renomeado; tentando religar a instancia antiga." >&2
    docker start "$old_container" >/dev/null 2>&1 || true
    return 1
  fi

  echo "[dockermt] atualizando runtime..."
  runtime_src_dockermt="/usr/local/bin/dockermt"
  runtime_src_shell="/usr/local/bin/dockermt-instance-shell"
  runtime_src_args="/opt/dockermt-full/dist/lib/args.js"
  runtime_src_dispatch="/opt/dockermt-full/dist/lib/dispatch.js"
  if [ -f /config/.dockermt/patches/runtime/dockermt ]; then
    runtime_src_dockermt="/config/.dockermt/patches/runtime/dockermt"
  fi
  if [ -f /config/.dockermt/patches/runtime/dockermt-instance-shell ]; then
    runtime_src_shell="/config/.dockermt/patches/runtime/dockermt-instance-shell"
  fi
  if [ -f /config/.dockermt/patches/runtime/args.js ]; then
    runtime_src_args="/config/.dockermt/patches/runtime/args.js"
  fi
  if [ -f /config/.dockermt/patches/runtime/dispatch.js ]; then
    runtime_src_dispatch="/config/.dockermt/patches/runtime/dispatch.js"
  fi
  docker cp "$runtime_src_dockermt" "${new_container}:/usr/local/bin/dockermt"
  if [ -f "$runtime_src_shell" ]; then
    docker cp "$runtime_src_shell" "${new_container}:/usr/local/bin/dockermt-instance-shell"
  fi
  if [ -f "$runtime_src_args" ]; then
    docker cp "$runtime_src_args" "${new_container}:/opt/dockermt-full/dist/lib/args.js"
  fi
  if [ -f "$runtime_src_dispatch" ]; then
    docker cp "$runtime_src_dispatch" "${new_container}:/opt/dockermt-full/dist/lib/dispatch.js"
  fi
  docker exec "$new_container" sh -lc 'chmod 755 /usr/local/bin/dockermt /usr/local/bin/dockermt-instance-shell 2>/dev/null || true'
  docker exec "$new_container" /usr/local/bin/dockermt-project-meta init >/dev/null 2>&1 || true

  docker rm "$old_container" >/dev/null 2>&1 || true
  rename_instance_mt5_window_in_container "$new_container" ":1" "$new_short" >/dev/null 2>&1 || true

  cat <<EOF2
[dockermt] instancia renomeada.
from         : $old_container
to           : $new_container
config-volume: $config_volume
state-volume : $state_volume
url          : $(runtime_web_url "$new_container")
shell        : dockermt @$new_short shell
open         : dockermt @$new_short container open
status       : dockermt @$new_short container status
EOF2
}

runtime_instance_rename_request() {
  require_docker
  local new_raw="${1:-}"
  [ -n "$new_raw" ] || { echo "ERR: uso: dockermt instance rename <novo-nome>" >&2; return 1; }

  local current_name current_short new_short central_name
  current_name="$(resolve_current_runtime_container)"
  runtime_is_instance "$current_name" || {
    echo "ERR: 'dockermt instance rename' so pode ser usado dentro de uma instancia." >&2
    return 1
  }
  if [ "${ROUTED_EXPLICIT_TARGET:-0}" = "1" ]; then
    echo "ERR: 'dockermt instance rename' so pode ser executado localmente dentro da instancia (sem @)." >&2
    return 1
  fi

  current_short="$(runtime_short_name "$current_name")"
  new_short="$(sanitize_snapshot_name "$new_raw")"
  [ -n "$new_short" ] || { echo "ERR: novo nome invalido." >&2; return 1; }
  if [ "$new_short" = "$current_short" ]; then
    echo "[dockermt] rename sem alteracao: ${current_short}"
    return 0
  fi

  central_name="$(resolve_central_runtime_container)"
  [ -n "$central_name" ] || { echo "ERR: runtime central nao localizado para processar o rename." >&2; return 1; }
  if ! docker exec -d "$central_name" /usr/local/bin/dockermt _instance-rename "$current_name" "$new_short" >/dev/null 2>&1; then
    echo "ERR: falha ao enviar a solicitacao de rename para o runtime central." >&2
    return 1
  fi

  cat <<EOF2
[dockermt] solicitacao de rename enviada.
from         : $current_short
to           : $new_short
observe      : dockermt instance list
novo acesso  : dockermt @$new_short ...
EOF2
}

