sanitize_snapshot_name() {
  local raw="${1:-snapshot}"
  raw="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]')"
  raw="$(printf '%s' "$raw" | sed 's/[^a-z0-9._-]/-/g; s/-\{2,\}/-/g; s/^-//; s/-$//')"
  if [ -z "$raw" ]; then
    raw="snapshot"
  fi
  printf '%s\n' "$raw"
}

build_snapshot_id() {
  printf '%s.v%s-%s\n' "$1" "$2" "$3"
}

snapshot_image_ref_from_id() {
  printf '%s:%s\n' "$SNAPSHOT_REPO" "$1"
}

snapshot_volume_name_from_id() {
  printf '%s.%s\n' "$SNAPSHOT_VOLUME_PREFIX" "$1"
}

resolve_pull_image_ref() {
  local raw_ref="${1:-}"
  if [ -z "$raw_ref" ]; then
    return 1
  fi
  case "$raw_ref" in
    *@sha256:*)
      printf '%s\n' "$raw_ref"
      ;;
    */*:*|*.*:*|*:*/*)
      printf '%s\n' "$raw_ref"
      ;;
    */*)
      printf '%s\n' "$raw_ref"
      ;;
    *:*)
      printf '%s\n' "${PULL_REPO}/$raw_ref"
      ;;
    *)
      printf '%s:%s\n' "$PULL_REPO" "$raw_ref"
      ;;
  esac
}

latest_snapshot_id() {
  docker image ls "$SNAPSHOT_REPO" --format '{{.Repository}}:{{.Tag}}' 2>/dev/null | while read -r ref; do
    [ -n "$ref" ] || continue
    docker image inspect "$ref" --format '{{index .Config.Labels "dockermt.snapshot.timestamp"}}|{{index .Config.Labels "dockermt.snapshot.id"}}' 2>/dev/null || true
  done | awk -F'|' '$1 != "" && $1 != "<no value>" && $2 != "" && $2 != "<no value>" {print $0}' | sort | tail -n 1 | cut -d'|' -f2
}

ensure_state_volume() {
  docker volume inspect "$STATE_VOLUME" >/dev/null 2>&1 || docker volume create "$STATE_VOLUME" >/dev/null
}

read_selected_snapshot_id() {
  docker volume inspect "$STATE_VOLUME" >/dev/null 2>&1 || return 0
  docker run --rm -u 0 -v "${STATE_VOLUME}:/state" alpine sh -lc '
    f="/state/$1"
    [ -f "$f" ] || exit 0
    cat "$f"
  ' sh "$STATE_SELECTED_FILE" 2>/dev/null | head -n 1
}

clear_selected_snapshot_id() {
  docker volume inspect "$STATE_VOLUME" >/dev/null 2>&1 || return 0
  docker run --rm -u 0 -v "${STATE_VOLUME}:/state" alpine sh -lc '
    rm -f "/state/$1"
  ' sh "$STATE_SELECTED_FILE" >/dev/null 2>&1 || true
}

set_selected_snapshot_id() {
  local snapshot_id="${1:-}"
  [ -n "$snapshot_id" ] || return 1
  ensure_state_volume
  docker run --rm -u 0 \
    -e "SNAPSHOT_ID=$snapshot_id" \
    -e "STATE_SELECTED_FILE=$STATE_SELECTED_FILE" \
    -v "${STATE_VOLUME}:/state" alpine sh -lc '
      mkdir -p /state
      printf "%s\n" "$SNAPSHOT_ID" > "/state/$STATE_SELECTED_FILE"
    ' >/dev/null
}

selected_snapshot_id() {
  local snapshot_id snapshot_image snapshot_volume
  snapshot_id="$(read_selected_snapshot_id)"
  [ -n "$snapshot_id" ] || return 0
  snapshot_image="$(snapshot_image_ref_from_id "$snapshot_id")"
  snapshot_volume="$(snapshot_volume_name_from_id "$snapshot_id")"
  if docker image inspect "$snapshot_image" >/dev/null 2>&1 && docker volume inspect "$snapshot_volume" >/dev/null 2>&1; then
    printf '%s\n' "$snapshot_id"
    return 0
  fi
  clear_selected_snapshot_id
}

