project_summary_from_container() {
  local target_container="${1:-}"
  local target_volume="" target_image="" summary_json=""
  [ -n "$target_container" ] || return 0
  target_volume="$(current_container_config_volume "$target_container")"
  target_image="$(current_container_image "$target_container")"
  if [ -n "$target_volume" ] && [ -n "$target_image" ]; then
    summary_json="$(docker run --rm --entrypoint sh -v "${target_volume}:/config:ro" "$target_image" -lc '[ -f /config/.dockermt/project/project.json ] && cat /config/.dockermt/project/project.json || true' 2>/dev/null || true)"
  fi
  if [ -z "$summary_json" ]; then
    printf '%s\t%s\t%s\n' "-" "-" "0"
