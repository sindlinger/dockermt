_print_banner_line() {
  local text="$1"
  local width content pad_count
  content=" ${text} "
  width="${COLUMNS:-}"
  if ! printf '%s' "$width" | grep -Eq '^[0-9]+$'; then
    width=""
  fi
  if [ -z "$width" ] && command -v tput >/dev/null 2>&1; then
    width="$(tput cols 2>/dev/null || true)"
    if ! printf '%s' "$width" | grep -Eq '^[0-9]+$'; then
      width=""
    fi
  fi
  if [ -z "$width" ] || [ "$width" -lt 20 ]; then
    width=80
  fi
  pad_count=$(( width - ${#content} ))
  if [ "$pad_count" -gt 0 ]; then
    content="${content}$(printf '%*s' "$pad_count" '')"
  fi
  if [ -n "$CLR_BANNER_BG" ]; then
    printf '%b\n' "${CLR_BANNER_BG}${CLR_BANNER_FG}${content}${CLR_RST}"
  else
    printf '%s\n' "$content"
  fi
}

_print_cli_banner() {
  _print_banner_line "DockerMT • dockermt v${DOCKERMT_VERSION_CURRENT}"
  _print_banner_line "Socket: ${HOST}:${PORT}"
}

_list_extension_command_names() {
  local dir="/config/${DOCKERMT_EXTENSION_COMMANDS_REL}"
  [ -d "$dir" ] || return 0
  find "$dir" -maxdepth 1 -type f \( -name '*.sh' -o -name '*.py' -o -name '*.js' \) 2>/dev/null \
    | sed 's#.*/##; s/\.[^.]*$//' \
    | sort -u \
    | grep -Ev '^(help|version|instance|whoami|shell|import|project|map|ping|install|dukascopy|container|gpu|compile|editor|add|rm|inspect|debug|trace|log|config|chart|template|expert|tester|hotkey|script|trade|global|input|snapshot|object|screen|addons|quit)$' || true
}

_extension_command_path() {
  local name="${1:-}"
  local dir="/config/${DOCKERMT_EXTENSION_COMMANDS_REL}"
  [ -n "$name" ] || return 1
  [ -d "$dir" ] || return 1
  for candidate in "$dir/$name.sh" "$dir/$name.py" "$dir/$name.js" "$dir/$name"; do
    [ -f "$candidate" ] && { printf '%s\n' "$candidate"; return 0; }
  done
  return 1
}

_run_extension_command() {
  local name="${1:-}"
  shift || true
  local ext_path
  ext_path="$(_extension_command_path "$name" 2>/dev/null || true)"
  [ -n "$ext_path" ] || return 1
  case "$ext_path" in
    *.sh|"")
      DOCKERMT_EXTENSION_NAME="$name" DOCKERMT_EXTENSION_PATH="$ext_path" bash "$ext_path" "$@"
      ;;
    *.py)
      DOCKERMT_EXTENSION_NAME="$name" DOCKERMT_EXTENSION_PATH="$ext_path" python3 "$ext_path" "$@"
      ;;
    *.js)
      DOCKERMT_EXTENSION_NAME="$name" DOCKERMT_EXTENSION_PATH="$ext_path" node "$ext_path" "$@"
      ;;
    *)
      DOCKERMT_EXTENSION_NAME="$name" DOCKERMT_EXTENSION_PATH="$ext_path" "$ext_path" "$@"
      ;;
  esac
}

