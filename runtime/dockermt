runtime_mt5_path() {
  printf '/config/.wine/drive_c/Program Files/MetaTrader 5/terminal64.exe\n'
}

runtime_prepare_user_runtime_dir() {
  local runtime_dir="${XDG_RUNTIME_DIR:-/tmp/runtime-abc}"
  mkdir -p "$runtime_dir" >/dev/null 2>&1 || true
  if [ "$(id -u)" = "0" ]; then
    chown abc:abc "$runtime_dir" >/dev/null 2>&1 || true
  fi
  chmod 700 "$runtime_dir" >/dev/null 2>&1 || true
  printf '%s\n' "$runtime_dir"
}

runtime_run_as_mt5_user() {
  local cmd="${1:-}"
  local runtime_dir="${2:-}"
  [ -n "$cmd" ] || return 1
  [ -n "$runtime_dir" ] || runtime_dir="$(runtime_prepare_user_runtime_dir)"
  if [ "$(id -u)" = "0" ]; then
    su -s /bin/sh abc -c "XDG_RUNTIME_DIR='$runtime_dir' $cmd"
  else
    XDG_RUNTIME_DIR="$runtime_dir" sh -lc "$cmd"
  fi
}

runtime_mt5linux_start() {
  local target_display="${1:-}"
  local runtime_dir=""
  [ -n "$target_display" ] || return 1
  local out_log err_log
  out_log="/config/dockermt/runtime/mt5linux-open.out"
  err_log="/config/dockermt/runtime/mt5linux-open.err"
  mkdir -p /config/dockermt/runtime
  chown -R abc:abc /config/dockermt/runtime
  runtime_dir="$(runtime_prepare_user_runtime_dir)"
  runtime_run_as_mt5_user "DISPLAY='$target_display' WINEPREFIX='/config/.wine' nohup wine python -m mt5linux --host 0.0.0.0 -p '${MT5_PY_PORT:-8001}' >'$out_log' 2>'$err_log' &" "$runtime_dir" >/dev/null 2>&1
}

runtime_mt5_window_title() {
  local instance_name
  instance_name="${DOCKERMT_INSTANCE_NAME:-${HOSTNAME:-dockermt}}"
  printf 'DockerMT [%s] MT5\n' "$instance_name"
}

runtime_mt5_window_id() {
  local target_display="${1:-}"
  local runtime_dir="" listing
  [ -n "$target_display" ] || return 1
  runtime_dir="$(runtime_prepare_user_runtime_dir)"
  listing="$(runtime_run_as_mt5_user "DISPLAY='$target_display' wmctrl -lx" "$runtime_dir" 2>/dev/null || true)"
  printf '%s\n' "$listing" | awk '$3 ~ /terminal64\.exe\.terminal64\.exe/ { print $1; exit }'
}

runtime_rename_mt5_window() {
  local target_display="${1:-}"
  local runtime_dir=""
  [ -n "$target_display" ] || return 1
  local window_id title
  window_id="$(runtime_mt5_window_id "$target_display")"
  [ -n "$window_id" ] || return 1
  title="$(runtime_mt5_window_title)"
  runtime_dir="$(runtime_prepare_user_runtime_dir)"
  runtime_run_as_mt5_user "DISPLAY='$target_display' wmctrl -ir '$window_id' -T '$title'" "$runtime_dir" >/dev/null 2>&1 || return 1
}

runtime_wait_and_rename_mt5_window() {
  local target_display="${1:-}"
  local tries="${2:-12}"
  [ -n "$target_display" ] || return 1
  while [ "$tries" -gt 0 ]; do
    if runtime_rename_mt5_window "$target_display"; then
      return 0
    fi
    sleep 1
    tries=$((tries - 1))
  done
  return 1
}

rename_instance_mt5_window_in_container() {
  local target_container="${1:-}"
  local target_display="${2:-:1}"
  local instance_name="${3:-}"
  local tries=30
  local win=""
  [ -n "$target_container" ] || return 1
  [ -n "$instance_name" ] || return 1
  while [ "$tries" -gt 0 ]; do
    win="$(docker exec "$target_container" sh -lc "su -s /bin/sh abc -c 'DISPLAY=${target_display} wmctrl -lx'" 2>/dev/null | awk '$3 ~ /terminal64\.exe\.terminal64\.exe/ { print $1; exit }' || true)"
    if [ -n "$win" ]; then
      docker exec "$target_container" sh -lc "su -s /bin/sh abc -c \"DISPLAY=${target_display} wmctrl -ir $win -T 'DockerMT [${instance_name}] MT5'\"" >/dev/null 2>&1 || true
      return 0
    fi
    sleep 1
    tries=$((tries - 1))
  done
  return 1
}

runtime_open_mt5_on_display() {
  local target_display="${1:-}"
  local launch_err window_id log_reason runtime_dir
  RUNTIME_MT5_OPEN_REASON=""
  [ -n "$target_display" ] || return 1
  local mt5file out_log err_log
  mt5file="$(runtime_mt5_path)"
  if [ ! -f "$mt5file" ]; then
    RUNTIME_MT5_OPEN_REASON="terminal64.exe nao encontrado em $mt5file"
    return 1
  fi
  if ! command -v wine >/dev/null 2>&1; then
    RUNTIME_MT5_OPEN_REASON="wine nao encontrado no runtime"
    return 1
  fi
  out_log="/config/dockermt/runtime/mt5-open.out"
  err_log="/config/dockermt/runtime/mt5-open.err"
  mkdir -p /config/dockermt/runtime
  chown -R abc:abc /config/dockermt/runtime
  runtime_dir="$(runtime_prepare_user_runtime_dir)"
  runtime_run_as_mt5_user "WINEPREFIX='/config/.wine' wineserver -k" "$runtime_dir" >/dev/null 2>&1 || true
  sleep 3
  launch_err="$(runtime_run_as_mt5_user "DISPLAY='$target_display' WINEPREFIX='/config/.wine' WINEDEBUG='-all' nohup wine '$mt5file' >'$out_log' 2>'$err_log' &" "$runtime_dir" 2>&1 >/dev/null || true)"
  if [ -n "$launch_err" ]; then
    launch_err="$(printf '%s' "$launch_err" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//')"
    RUNTIME_MT5_OPEN_REASON="falha ao iniciar MT5 no display $target_display: $launch_err"
    return 1
  fi
  sleep 6
  window_id="$(runtime_mt5_window_id "$target_display" || true)"
  if [ -z "$window_id" ]; then
    log_reason="$(sed -n '1p' "$err_log" 2>/dev/null | tr -d '\r' || true)"
    if [ -n "$log_reason" ]; then
      RUNTIME_MT5_OPEN_REASON="$log_reason"
    else
      RUNTIME_MT5_OPEN_REASON="janela do MT5 nao apareceu no display $target_display"
    fi
    return 1
  fi
  runtime_wait_and_rename_mt5_window "$target_display" 12 >/dev/null 2>&1 || true
  runtime_mt5linux_start "$target_display"
  return 0
}

