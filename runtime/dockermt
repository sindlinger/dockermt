_route_named_runtime() {
  local raw="${1:-}"
  local target_key target_container current_name current_label
  case "$raw" in
    @*)
      ROUTED_EXPLICIT_TARGET=1
      target_key="${raw#@}"
      [ -n "$target_key" ] || { echo "ERR: instancia vazia em '@'." >&2; exit 1; }
      target_container="$(normalize_runtime_target "$target_key")"
      container_exists "$target_container" || { echo "ERR: instancia nao localizada: $target_key" >&2; exit 1; }
      runtime_ensure_running "$target_container" || { echo "ERR: nao foi possivel iniciar a instancia: $target_key" >&2; exit 1; }
      shift || true
      if [ "$#" -eq 0 ]; then
        set -- container status
      fi
      current_name="$(resolve_current_runtime_container)"
      case "${1:-}" in
        shell)
          shift || true
          docker_exec_runtime_shell "$target_container" "$target_key" "$@"
          exit $?
          ;;
        import)
          shift || true
          runtime_import_named "$target_container" "$target_key" "$@"
          exit $?
          ;;
        sync)
          echo "ERR: comando removido: dockermt @${target_key} sync" >&2
          exit 1
          ;;
      esac
      if [ "$target_container" = "$current_name" ]; then
        export DOCKERMT_CONTAINER_NAME="$target_container"
        ROUTED_ARGS=("$@")
        return 0
      fi
      current_label="$(runtime_short_name "$current_name")"
      echo "[dockermt] roteamento: @${target_key} via ${current_label} -> ${target_container}"
      DOCKERMT_ROUTED_EXPLICIT_TARGET=1 docker_exec_runtime_cli "$target_container" "$@"
      exit $?
      ;;
  esac
  return 1
}

ROUTED_EXPLICIT_TARGET="${DOCKERMT_ROUTED_EXPLICIT_TARGET:-0}"
ROUTED_ARGS=("$@")
if _route_named_runtime "$@"; then
  set -- "${ROUTED_ARGS[@]}"
fi
CMD="${1:-help}"

case "$CMD" in
  help|-h|--help)
    shift || true
    if [ "$#" -eq 0 ]; then
      _usage
    else
      _root_topic_usage "$@" || {
        if _extension_command_path "${1:-}" >/dev/null 2>&1; then
          _run_extension_command "${1:-}" help "${@:2}"
        else
          echo "ERR: topico de ajuda desconhecido: $*" >&2
          _usage >&2
          exit 1
        fi
      }
    fi
    ;;
  map)
    cat <<EOF2
DOCKERMT Container Map
======================
Container: ${HOSTNAME:-dockermt}
DockerMT: ${DOCKERMT_VERSION_CURRENT}
Socket CLI: ${DOCKERMT_VERSION_CURRENT}

Ports
-----
- Web (KasmVNC): host ${WEB_PORT} -> container 3000
- Python bridge: host ${PY_PORT} -> container 8001
- TelnetMT socket: host ${PORT} -> container ${PORT}

Important paths
---------------
- /config
- /config/.wine/drive_c/Program Files/MetaTrader 5
- /config/.wine/drive_c/Program Files/MetaTrader 5/MQL5
- /config/.wine/drive_c/Program Files/MetaTrader 5/Config/services.ini
- /usr/local/bin/dockermt
- Docker socket: ${DOCKER_SOCKET_PATH}
EOF2
    ;;
  send)
    _legacy_command_disabled
    ;;
  ping)
    _send_line "1|PING"
    ;;
  shell)
    shift || true
    runtime_shell_current "$@"
    ;;
  instance|whoami)
    shift || true
    sub="${1:-show}"
    case "$sub" in
      list|instances|ls|factory|create)
        if [ "${ROUTED_EXPLICIT_TARGET:-0}" != "1" ] && runtime_is_instance "$(resolve_current_runtime_container)"; then
          central_runtime_name="$(resolve_central_runtime_container)"
          if [ -n "$central_runtime_name" ] && [ "$central_runtime_name" != "$(resolve_current_runtime_container)" ]; then
            docker_exec_runtime_cli "$central_runtime_name" instance "$sub" "${@:2}"
            exit $?
          fi
        fi
        ;;
    esac
    case "$sub" in
      show|name|"")
        printf '%s\n' "$(runtime_short_name "$(resolve_current_runtime_container)")"
        ;;
      list|instances|ls)
        print_runtime_instances
        ;;
      factory)
        shift || true
        print_factory_workspace_info "${1:-show}"
        ;;
      create)
        shift || true
        runtime_spawn "$@"
        ;;
      rename)
        shift || true
        runtime_instance_rename_request "${1:-}"
        ;;
      help|-h|--help)
        _root_topic_usage instance
        ;;
      *)
        echo "ERR: subcomando desconhecido em 'dockermt instance': $sub" >&2
        _root_topic_usage instance >&2
        exit 1
        ;;
    esac
    ;;
  project)
    shift || true
    project_meta_cli "$@"
    ;;
  socket)
    _socket_namespace_removed
    ;;
  dukascopy)
    shift || true
    sub="${1:-help}"
    shift || true
    case "$sub" in
      help|-h|--help)
        if [ "$#" -eq 0 ]; then
          _dukascopy_usage
        else
          _dukascopy_topic_usage "$1"
        fi
        ;;
      sync)
        dukascopy_sync
        ;;
      *)
        echo "ERR: subcomando desconhecido em 'dockermt dukascopy': $sub" >&2
        _dukascopy_usage >&2
        exit 1
        ;;
    esac
    ;;
  container)
    if [ "${ROUTED_EXPLICIT_TARGET:-0}" != "1" ] && runtime_is_instance "$(resolve_current_runtime_container)"; then
      implied_sub="${2:-status}"
      if [ "$implied_sub" = "open" ]; then
        self_short="$(runtime_short_name "$(resolve_current_runtime_container)")"
        echo "ERR: 'dockermt container open' dentro da instancia exige alvo explicito com @." >&2
        echo "Use: dockermt @${self_short} container open" >&2
        exit 1
      fi
      central_runtime_name="$(resolve_central_runtime_container)"
      if [ -n "$central_runtime_name" ] && [ "$central_runtime_name" != "$(resolve_current_runtime_container)" ]; then
        docker_exec_runtime_cli "$central_runtime_name" "$@"
        exit $?
      fi
    fi
    shift || true
    sub="${1:-status}"
    shift || true
    case "$sub" in
      help|-h|--help)
        if [ "$#" -eq 0 ]; then
          _container_usage
        else
          _container_topic_usage "$1"
        fi
        ;;
      status)
        print_runtime_status "${1:-}"
        ;;
      map)
        _legacy_command_disabled
        ;;
      up)
        runtime_up "${1:-}"
        ;;
      open)
        runtime_open "$@"
        ;;
      list)
        print_snapshots
        ;;
      save)
        runtime_save_alias "${1:-}"
        ;;
      restore)
        runtime_restore_alias "${1:-}"
        ;;
      commit)
        snapshot_commit "$@"
        ;;
      pull)
        snapshot_pull "${1:-}"
        ;;
      push)
        snapshot_push "${1:-}"
        ;;
      select)
        snapshot_select "${1:-}"
        ;;
      snapshots)
        print_snapshots
        ;;
      *)
        echo "ERR: subcomando desconhecido em 'dockermt container': $sub" >&2
        _container_usage >&2
        exit 1
        ;;
    esac
    ;;
  shim-print)
    _host_integration_disabled
    ;;
  install-shim)
    _host_integration_disabled
    ;;
  install-help)
    _host_integration_disabled
    ;;
  install)
    shift || true
    runtime_install "$@"
    ;;
  sync)
    echo "ERR: comando removido: dockermt sync" >&2
    exit 1
    ;;
  _instance-rename)
    shift || true
    runtime_instance_rename_apply "$@"
    ;;
  *)
    if _extension_command_path "$CMD" >/dev/null 2>&1; then
      shift || true
      _run_extension_command "$CMD" "$@"
    else
      socket_cli "$@"
    fi
    ;;
esac
