_resolve_runtime_version() {
  if [ -f "$DOCKERMT_VERSION_FILE" ]; then
    local version
    version="$(tr -d '\r' < "$DOCKERMT_VERSION_FILE" | sed -n '1p')"
    if [ -n "$version" ]; then
      printf '%s\n' "$version"
      return 0
    fi
  fi
  if [ -n "${DOCKERMT_VERSION:-}" ]; then
    printf '%s\n' "$DOCKERMT_VERSION"
    return 0
  fi
  printf 'dev\n'
}

DOCKERMT_VERSION_CURRENT="$(_resolve_runtime_version)"
CMDMT_VERSION_CURRENT="${CMDMT_VERSION_CURRENT:-$DOCKERMT_VERSION_CURRENT}"

_resolve_banner_color_name() {
  if [ -n "${DOCKERMT_BANNER_COLOR:-}" ]; then
    printf '%s\n' "${DOCKERMT_BANNER_COLOR}"
    return 0
  fi
  if [ -f "$DOCKERMT_CONFIG_FILE" ] && command -v python3 >/dev/null 2>&1; then
    local resolved
    resolved="$(python3 - "$DOCKERMT_CONFIG_FILE" <<'PY'
import json, sys
path = sys.argv[1]
try:
    with open(path, 'r', encoding='utf-8') as fh:
        obj = json.load(fh)
    ui = obj.get('ui') if isinstance(obj, dict) else None
    val = ui.get('bannerColor') if isinstance(ui, dict) else None
    if isinstance(val, str) and val.strip():
        print(val.strip())
except Exception:
    pass
PY
)"
    if [ -n "$resolved" ]; then
      printf '%s\n' "$resolved"
      return 0
    fi
  fi
  printf 'yellow\n'
}

