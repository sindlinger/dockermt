  case "$sub" in
    ""|list)
      DOCKERMT_INSTANCE_NAME="${DOCKERMT_INSTANCE_NAME:-$(normalize_runtime_target)}" \
        /usr/local/bin/dockermt-project-meta list-projects
      ;;
    log)
      [ "$#" -gt 0 ] || { echo "ERR: uso: dockermt project log <projeto>" >&2; return 1; }
      DOCKERMT_INSTANCE_NAME="${DOCKERMT_INSTANCE_NAME:-$(normalize_runtime_target)}" \
        /usr/local/bin/dockermt-project-meta log-project "$1"
      ;;
    json)
      [ "$#" -gt 0 ] || { echo "ERR: uso: dockermt project json <projeto>" >&2; return 1; }
      DOCKERMT_INSTANCE_NAME="${DOCKERMT_INSTANCE_NAME:-$(normalize_runtime_target)}" \
        /usr/local/bin/dockermt-project-meta json-project "$1"
      ;;
    resume)
      project_network_resume "$@"
      ;;
    network-sync|sync-network)
      project_network_registry_refresh
      ;;
    network-json|json-network)
      project_network_registry_refresh >/dev/null
      project_network_registry_print_json
      ;;
    network|net|all|registry)
      case "${1:-projects}" in
        ""|projects|list)
          project_network_registry_refresh >/dev/null
          project_network_registry_print_projects
          ;;
        instances|status)
          project_network_registry_refresh >/dev/null
          project_network_registry_print_instances
          ;;
        json)
          project_network_registry_refresh >/dev/null
          project_network_registry_print_json
          ;;
        sync)
          project_network_registry_refresh
          ;;
        resume)
          shift || true
          project_network_resume "$@"
          ;;
        *)
          echo "ERR: uso: dockermt project network [projects|instances|json|sync|resume INSTANCIA [PROJETO]]" >&2
          return 1
          ;;
      esac
      ;;
    *)
      DOCKERMT_INSTANCE_NAME="${DOCKERMT_INSTANCE_NAME:-$(normalize_runtime_target)}" \
        /usr/local/bin/dockermt-project-meta show-project "$sub"
      ;;
  esac
}

