project_network_registry_refresh() {
  require_docker
  local central_name
  central_name="$(resolve_central_runtime_container)"
  mkdir -p "$DOCKERMT_PROJECTS_REGISTRY_DIR"
  python3 - "$central_name" "$DOCKERMT_PROJECTS_NETWORK_FILE" "$DOCKERMT_PROJECTS_NETWORK_EVENTS_FILE" <<'PY'
import datetime as _dt
import json
import os
import subprocess
import sys

central_name, out_json, out_events = sys.argv[1:4]


def now():
    return _dt.datetime.utcnow().replace(microsecond=0).isoformat() + "Z"


def run(cmd):
    return subprocess.run(cmd, text=True, capture_output=True)


def inspect_container(name):
    r = run(["docker", "inspect", name])
    if r.returncode != 0:
        return None
    try:
        arr = json.loads(r.stdout)
        if isinstance(arr, list) and arr:
            return arr[0]
    except Exception:
        return None
    return None


def host_port(inspect_obj, port_key):
    ports = ((inspect_obj or {}).get("NetworkSettings") or {}).get("Ports") or {}
    mappings = ports.get(port_key) or []
    if isinstance(mappings, list) and mappings:
        first = mappings[0] or {}
        value = first.get("HostPort")
        if value:
            return str(value)
    return "-"


def parse_projects_table(table_text):
    rows = []
    lines = [ln for ln in table_text.splitlines() if ln.strip()]
    if not lines:
        return rows
    for line in lines[1:]:
        cols = line.split("\t")
        if len(cols) < 6:
            continue
        rows.append(
            {
                "project_id": cols[0],
                "repo_name": cols[1],
                "last_access": cols[2],
                "codex_session": cols[3],
                "present": cols[4],
                "path": cols[5],
            }
        )
    return rows


containers_result = run(["docker", "ps", "-a", "--format", "{{.Names}}"])
container_names = [ln.strip() for ln in containers_result.stdout.splitlines() if ln.strip()]

items = []
for name in container_names:
    obj = inspect_container(name)
    if not obj:
        continue
    labels = (obj.get("Config") or {}).get("Labels") or {}
    is_runtime_instance = labels.get("dockermt.runtime") == "1"
    parent = labels.get("dockermt.runtime.parent") or ""
    if name != central_name:
        if not is_runtime_instance:
            continue
        if parent and parent != central_name:
            continue
    state = (obj.get("State") or {}).get("Status") or "unknown"
    running = state == "running"
    instance_key = labels.get("dockermt.runtime.name") or (name[9:] if name.startswith("dockermt-") else name)
    entry = {
        "container": name,
        "instance": instance_key,
        "scope": "central" if name == central_name else "instance",
        "parent": parent if name != central_name else "",
        "status": state,
        "running": running,
        "web_port": host_port(obj, "3000/tcp"),
        "telnet_port": host_port(obj, "1122/tcp"),
        "python_port": host_port(obj, "8001/tcp"),
        "codex_sessions_total": 0,
        "meta": {},
        "projects": [],
        "errors": [],
    }
    if running:
        meta_result = run(["docker", "exec", name, "/usr/local/bin/dockermt-project-meta", "json-instance"])
        if meta_result.returncode == 0 and meta_result.stdout.strip():
            try:
                entry["meta"] = json.loads(meta_result.stdout)
            except Exception as exc:
                entry["errors"].append(f"meta-json: {exc}")
        else:
            stderr = (meta_result.stderr or "").strip()
            if stderr:
                entry["errors"].append(stderr)
        projects_result = run(["docker", "exec", name, "/usr/local/bin/dockermt-project-meta", "list-projects"])
        if projects_result.returncode == 0:
            entry["projects"] = parse_projects_table(projects_result.stdout or "")
        else:
            stderr = (projects_result.stderr or "").strip()
            if stderr:
                entry["errors"].append(stderr)
        events_result = run(["docker", "exec", name, "/usr/local/bin/dockermt-project-meta", "log-instance"])
        if events_result.returncode == 0:
            sessions_total = 0
            for line in (events_result.stdout or "").splitlines():
                line = line.strip()
                if not line:
                    continue
                try:
                    item = json.loads(line)
                except Exception:
                    continue
                if isinstance(item, dict) and item.get("event") == "start-codex":
                    sessions_total += 1
            entry["codex_sessions_total"] = sessions_total
        else:
            stderr = (events_result.stderr or "").strip()
            if stderr:
                entry["errors"].append(stderr)
    items.append(entry)

items.sort(key=lambda x: (0 if x.get("scope") == "central" else 1, x.get("instance") or x.get("container")))
generated_at = now()
payload = {
    "kind": "dockermt-network-projects",
    "generated_at": generated_at,
    "central": central_name,
    "instances": items,
}
os.makedirs(os.path.dirname(out_json), exist_ok=True)
with open(out_json, "w", encoding="utf-8") as fh:
    json.dump(payload, fh, ensure_ascii=True, indent=2)
    fh.write("\n")
projects_total = sum(len(it.get("projects") or []) for it in items)
event = {
    "timestamp": generated_at,
    "event": "network-sync",
    "central": central_name,
    "instances": len(items),
    "projects_total": projects_total,
}
with open(out_events, "a", encoding="utf-8") as fh:
    fh.write(json.dumps(event, ensure_ascii=True) + "\n")
print(f"central      : {central_name}")
print(f"instances    : {len(items)}")
print(f"projects     : {projects_total}")
print(f"registry     : {out_json}")
PY
}

