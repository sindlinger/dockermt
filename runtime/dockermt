project_network_resolve_repo_root() {
  local target_container="${1:-}"
  local ref="${2:-}"
  [ -n "$target_container" ] || return 1
  docker exec -i "$target_container" python3 - "$ref" <<'PY'
import glob
import json
import os
import sys

ref = (sys.argv[1] or "").strip()
projects_root = "/config/.dockermt/projects"
instance_meta = "/config/.dockermt/project/project.json"

default_ref = ""
if not ref and os.path.exists(instance_meta):
    try:
        data = json.load(open(instance_meta, "r", encoding="utf-8"))
        default_ref = str(data.get("last_project_id") or "").strip()
    except Exception:
        default_ref = ""
if not ref:
    ref = default_ref

rows = []
for path in glob.glob(os.path.join(projects_root, "*", "project.json")):
    try:
        data = json.load(open(path, "r", encoding="utf-8"))
    except Exception:
        continue
    if not isinstance(data, dict):
        continue
    row = {
        "project_id": str(data.get("project_id") or ""),
        "slug": str(data.get("slug") or ""),
        "repo_name": str(data.get("repo_name") or ""),
        "repo_rel": str(data.get("repo_rel") or ""),
        "repo_root": str(data.get("repo_root") or ""),
    }
    rows.append(row)

def match(row, value):
    if not value:
        return False
    v = value.strip().lower()
    if not v:
        return False
    options = {
        row["project_id"].lower(),
        row["slug"].lower(),
        row["repo_name"].lower(),
        row["repo_rel"].lower(),
        row["repo_root"].lower(),
        os.path.basename(row["repo_root"]).lower(),
    }
    return v in options

if ref:
    for row in rows:
        if match(row, ref):
            if row["repo_root"]:
                print(row["repo_root"])
                raise SystemExit(0)
    raise SystemExit(1)

if rows:
    last = rows[0]
    if last["repo_root"]:
        print(last["repo_root"])
        raise SystemExit(0)
raise SystemExit(1)
PY
}

project_network_resume() {
  require_docker
  local target_key="${1:-}"
  local project_ref="${2:-}"
  [ -n "$target_key" ] || {
    echo "ERR: uso: dockermt project resume <instancia> [projeto]" >&2
    return 1
  }
  local target_container repo_root
  target_container="$(normalize_runtime_target "$target_key")"
  container_exists "$target_container" || {
    echo "ERR: instancia nao localizada: $target_key" >&2
    return 1
  }
  runtime_ensure_running "$target_container" || {
    echo "ERR: nao foi possivel iniciar a instancia: $target_key" >&2
    return 1
  }
  repo_root="$(project_network_resolve_repo_root "$target_container" "$project_ref" 2>/dev/null || true)"
  [ -n "$repo_root" ] || {
    echo "ERR: projeto nao localizado na instancia '$target_key'." >&2
    return 1
  }
  local -a exec_flags=(-i)
  if [ -t 0 ] && [ -t 1 ]; then
    exec_flags=(-it)
  fi
  docker exec \
    "${exec_flags[@]}" \
    -e "DOCKERMT_RESUME_REPO_ROOT=$repo_root" \
    "$target_container" /bin/bash -lc '
      cd "$DOCKERMT_RESUME_REPO_ROOT" 2>/dev/null || {
        echo "ERR: projeto nao encontrado em $DOCKERMT_RESUME_REPO_ROOT" >&2
        exit 1
      }
      exec bash -i
    '
}

project_meta_forward_to_central_if_needed() {
  local sub="${1:-}"
  shift || true
  local current_name central_name
  case "$sub" in
    network|net|all|registry|resume|network-sync|sync-network|network-json|json-network)
      ;;
    *)
      return 1
      ;;
  esac
  current_name="$(resolve_current_runtime_container)"
  runtime_is_instance "$current_name" || return 1
  [ "${ROUTED_EXPLICIT_TARGET:-0}" != "1" ] || return 1
  central_name="$(resolve_central_runtime_container)"
  [ -n "$central_name" ] || return 1
  [ "$central_name" != "$current_name" ] || return 1
  docker_exec_runtime_cli "$central_name" project "$sub" "$@"
  return 0
}

project_meta_cli() {
  local sub="${1:-}"
