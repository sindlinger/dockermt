refresh_factory_workspace_from_runtime() {
  require_docker
  local source_volume="${1:-}"
  [ -n "$source_volume" ] || source_volume="$(current_runtime_source_volume)"
  [ -n "$source_volume" ] || { echo "ERR: nao foi possivel localizar o volume /config do runtime atual." >&2; return 1; }
  docker volume inspect "$DOCKERMT_WORKSPACE_ZERO_VOLUME" >/dev/null 2>&1 || docker volume create "$DOCKERMT_WORKSPACE_ZERO_VOLUME" >/dev/null
  docker run --rm \
    -e "RUNTIME_UID=${DOCKERMT_RUNTIME_UID}" \
    -e "RUNTIME_GID=${DOCKERMT_RUNTIME_GID}" \
    -e "FACTORY_VOLUME_NAME=${DOCKERMT_WORKSPACE_ZERO_VOLUME}" \
    -e "FACTORY_VERSION=${DOCKERMT_VERSION_CURRENT}" \
    -e "MT5_ROOT_REL=${DOCKERMT_MT5_ROOT_REL}" \
    -e "MQL5_ROOT_REL=${DOCKERMT_MQL5_ROOT_REL}" \
    -v "${source_volume}:/srcconfig:ro" \
    -v "${DOCKERMT_WORKSPACE_ZERO_VOLUME}:/factory" \
    alpine sh -lc '
      set -eu
      src_mt5="/srcconfig/${MT5_ROOT_REL}"
      src_mql5="/srcconfig/${MQL5_ROOT_REL}"
      dst_mt5="/factory/MT5ROOT"
      dst="$dst_mt5/MQL5"
      [ -d "$src_mt5" ] || exit 1
      [ -d "$src_mql5" ] || exit 1
      find /factory -mindepth 1 -maxdepth 1 -exec rm -rf {} + || true
      mkdir -p "$dst_mt5"
      cd "$src_mt5" && tar cf - . | (cd "$dst_mt5" && tar xf -)
      rm -rf "$dst"
      mkdir -p \
        "$dst/Indicators" \
        "$dst/Experts" \
        "$dst/Libraries" \
        "$dst/Services" \
        "$dst/Scripts" \
        "$dst/Files" \
        "$dst/Include"

      copy_rel() {
        rel="$1"
        [ -e "$src_mql5/$rel" ] || return 0
        mkdir -p "$dst/$(dirname "$rel")"
        cd "$src_mql5" && tar cf - "$rel" | (cd "$dst" && tar xf -)
      }

      copy_rel "Indicators/Examples"
      copy_rel "Indicators/Free Indicators"
      copy_rel "Experts/Advisors"
      copy_rel "Experts/Examples"
      copy_rel "Experts/Free Robots"
      copy_rel "Scripts/Examples"

      if [ -d "$src_mql5/Include" ]; then
        cd "$src_mql5/Include" && tar cf - . | (cd "$dst/Include" && tar xf -)
      fi
      if [ -d "$src_mql5/Libraries" ]; then
        cd "$src_mql5/Libraries" && tar cf - . | (cd "$dst/Libraries" && tar xf -)
      fi
      for service in TelnetMT_OficialTelnetServiceBootstrap.ex5 TelnetMT_SocketTelnetService.ex5; do
        if [ -f "$src_mql5/Services/$service" ]; then
          cp -f "$src_mql5/Services/$service" "$dst/Services/$service"
        fi
      done

      cat > /factory/FACTORY.md <<EOF
# DockerMT factory workspace

Volume:
- ${FACTORY_VOLUME_NAME}

Source:
- current runtime MT5 tree, with MQL5 pruned to factory-safe content

Contains:
- MQL5/Indicators
  - Examples
  - Free Indicators
- MQL5/Experts
  - Advisors
  - Examples
  - Free Robots
- MQL5/Libraries
- MQL5/Services
- MQL5/Scripts
  - Examples
- MQL5/Files
- MQL5/Include

Does not contain:
- Config
- Profiles
- Images
- Logs
- Shared Projects
- custom user indicators
- custom user experts
- custom user files
- Codex session state
- docs cache
- instance extensions
EOF
      cat > /factory/factory.json <<EOF
{
  "kind": "dockermt-workspace-factory",
  "name": "${FACTORY_VOLUME_NAME}",
  "version": "${FACTORY_VERSION}",
  "source": "current-runtime-with-pruned-mql5",
  "tree": [
    "MT5ROOT/MQL5/Indicators",
    "MT5ROOT/MQL5/Experts",
    "MT5ROOT/MQL5/Libraries",
    "MT5ROOT/MQL5/Services",
    "MT5ROOT/MQL5/Scripts",
    "MT5ROOT/MQL5/Files",
    "MT5ROOT/MQL5/Include"
  ],
  "indicators_allow": ["Examples", "Free Indicators"],
  "experts_allow": ["Advisors", "Examples", "Free Robots"],
  "scripts_allow": ["Examples"],
  "contains_runtime": true,
  "contains_user_custom_content": false
}
EOF
      chown -R "${RUNTIME_UID}:${RUNTIME_GID}" "$dst_mt5" 2>/dev/null || true
      chmod 644 /factory/FACTORY.md /factory/factory.json
    '
}

