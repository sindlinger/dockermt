auto_instance_banner_text_color() {
  local banner_color="${1:-}"
  case "$banner_color" in
    blue|magenta|red)
      printf 'white\n'
      ;;
    yellow|cyan|green|gray|grey)
      printf 'black\n'
      ;;
    *)
      local pair
      pair="$(random_instance_theme_pair)"
      printf '%s\n' "${pair##*:}"
      ;;
  esac
}

valid_instance_banner_color() {
  case "${1:-}" in
    yellow|blue|cyan|green|magenta|red|gray|grey)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

valid_instance_banner_text_color() {
  case "${1:-}" in
    black|red|green|yellow|blue|magenta|cyan|gray|grey|white|bright-white|gold|amber)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

assign_instance_banner_theme() {
  local target_volume="${1:-}"
  local instance_slug="${2:-}"
  local runtime_image="${3:-}"
  local preferred_color="${4:-}"
  local preferred_text="${5:-}"
  [ -n "$target_volume" ] || return 1
  [ -n "$instance_slug" ] || return 1
  [ -n "$runtime_image" ] || return 1
  local banner_color banner_text_color pair
  if [ -n "$preferred_color" ]; then
    valid_instance_banner_color "$preferred_color" || {
      echo "ERR: cor de banner invalida: $preferred_color" >&2
      return 1
    }
    banner_color="$preferred_color"
  else
    pair="$(random_instance_theme_pair)"
    banner_color="${pair%%:*}"
  fi
  if [ -n "$preferred_text" ]; then
    valid_instance_banner_text_color "$preferred_text" || {
      echo "ERR: cor de texto invalida: $preferred_text" >&2
      return 1
    }
    banner_text_color="$preferred_text"
  else
    if [ -n "${pair:-}" ]; then
      banner_text_color="${pair##*:}"
    else
      banner_text_color="$(auto_instance_banner_text_color "$banner_color")"
    fi
  fi
  docker run --rm \
    -i \
    --entrypoint python3 \
    -v "${target_volume}:/config" \
    "$runtime_image" \
    - "$banner_color" "$banner_text_color" <<'PY'
import json, pathlib, sys
cfg_path = pathlib.Path("/config/.dockermt/config.json")
cfg_path.parent.mkdir(parents=True, exist_ok=True)
color = sys.argv[1].strip()
text = sys.argv[2].strip()
try:
    cfg = json.loads(cfg_path.read_text("utf-8")) if cfg_path.exists() else {}
except Exception:
    cfg = {}
ui = cfg.get("ui") if isinstance(cfg.get("ui"), dict) else {}
ui["bannerColor"] = color
ui["bannerTextColor"] = text
ui["commandColor"] = color
cfg["ui"] = ui
cfg_path.write_text(json.dumps(cfg, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
PY
}

reset_target_workspace_from_zero() {
  local target_volume="${1:-}"
  [ -n "$target_volume" ] || return 1
  ensure_factory_workspace_volume
  if ! factory_has_runtime_install >/dev/null 2>&1; then
    refresh_factory_workspace_from_runtime >/dev/null 2>&1 || true
  fi
  docker run --rm \
    -e "MT5_ROOT_REL=${DOCKERMT_MT5_ROOT_REL}" \
    -e "MQL5_ROOT_REL=${DOCKERMT_MQL5_ROOT_REL}" \
    -e "RUNTIME_UID=${DOCKERMT_RUNTIME_UID}" \
    -e "RUNTIME_GID=${DOCKERMT_RUNTIME_GID}" \
    -v "${DOCKERMT_WORKSPACE_FACTORY_VOLUME}:/factory:ro" \
    -v "${target_volume}:/config" \
    alpine sh -lc '
      set -eu
      if [ -d /factory/MT5ROOT ]; then
        target_mt5="/config/${MT5_ROOT_REL}"
        mkdir -p "$target_mt5"
        find "$target_mt5" -mindepth 1 -maxdepth 1 -exec rm -rf {} +
        cd /factory/MT5ROOT && tar cf - . | (cd "$target_mt5" && tar xf -)
        chown -R "${RUNTIME_UID}:${RUNTIME_GID}" "$target_mt5" 2>/dev/null || true
        if [ -d /config/.wine ]; then
          chown -R "${RUNTIME_UID}:${RUNTIME_GID}" /config/.wine 2>/dev/null || true
        fi
      else
        target_mql5="/config/${MQL5_ROOT_REL}"
        mkdir -p "$target_mql5"
        find "$target_mql5" -mindepth 1 -maxdepth 1 -exec rm -rf {} +
        cd /factory/MQL5 && tar cf - . | (cd "$target_mql5" && tar xf -)
        chown -R "${RUNTIME_UID}:${RUNTIME_GID}" "$target_mql5"
        if [ -d /config/.wine ]; then
          chown -R "${RUNTIME_UID}:${RUNTIME_GID}" /config/.wine 2>/dev/null || true
        fi
      fi
    '
}

copy_single_mql5_item_into_volume() {
  local source_volume="${1:-}"
  local target_volume="${2:-}"
  local category="${3:-}"
  local raw_item="${4:-}"
  [ -n "$source_volume" ] || return 1
  [ -n "$target_volume" ] || return 1
  [ -n "$category" ] || return 1
  [ -n "$raw_item" ] || return 0
  docker run --rm \
    -e "ITEM_RAW=${raw_item}" \
    -e "CATEGORY=${category}" \
    -e "MQL5_ROOT_REL=${DOCKERMT_MQL5_ROOT_REL}" \
    -e "RUNTIME_UID=${DOCKERMT_RUNTIME_UID}" \
    -e "RUNTIME_GID=${DOCKERMT_RUNTIME_GID}" \
    -v "${source_volume}:/from:ro" \
    -v "${target_volume}:/to" \
    alpine sh -lc '
set -eu
rel="$(printf "%s" "${ITEM_RAW}" | tr "\\" "/")"
while [ "${rel#/}" != "$rel" ]; do
  rel="${rel#/}"
done
while [ "${rel%/}" != "$rel" ]; do
  rel="${rel%/}"
done
[ -n "$rel" ] || exit 0
src_root="/from/${MQL5_ROOT_REL}/${CATEGORY}"
dst_root="/to/${MQL5_ROOT_REL}/${CATEGORY}"
mkdir -p "$dst_root"
src="${src_root}/${rel}"
if [ ! -e "$src" ]; then
  rel_base="$(basename "$rel")"
  rel_noext="${rel%.mq5}"
  rel_noext="${rel_noext%.ex5}"
  if [ -e "${src_root}/${rel}.mq5" ]; then
    rel="${rel}.mq5"
    src="${src_root}/${rel}"
  elif [ -e "${src_root}/${rel}.ex5" ]; then
    rel="${rel}.ex5"
    src="${src_root}/${rel}"
  elif [ -e "${src_root}/${rel_noext}.mq5" ]; then
    rel="${rel_noext}.mq5"
    src="${src_root}/${rel}"
  elif [ -e "${src_root}/${rel_noext}.ex5" ]; then
    rel="${rel_noext}.ex5"
    src="${src_root}/${rel}"
  else
    found="$(find "$src_root" -mindepth 1 -maxdepth 6 \
      \( -type d -o -type f \) \
      \( -name "$rel_base" -o -name "${rel_base}.mq5" -o -name "${rel_base}.ex5" \) \
      | sort | head -n 1 || true)"
    if [ -n "$found" ]; then
      rel="${found#${src_root}/}"
      src="$found"
    fi
  fi
fi
if [ ! -e "$src" ]; then
  printf "ERR: %s nao localizado na base atual: %s\n" "$CATEGORY" "$ITEM_RAW" >&2
  exit 1
fi
mkdir -p "$dst_root/$(dirname "$rel")"
cp -a "$src" "$dst_root/$(dirname "$rel")/"
chown -R "${RUNTIME_UID}:${RUNTIME_GID}" "$dst_root"
'
}

copy_selected_mql5_items_into_volume() {
  local source_volume="${1:-}"
  local target_volume="${2:-}"
  local category="${3:-}"
  shift 3 || true
  [ "$#" -gt 0 ] || return 0
  local raw_item
  for raw_item in "$@"; do
    [ -n "$raw_item" ] || continue
    copy_single_mql5_item_into_volume "$source_volume" "$target_volume" "$category" "$raw_item"
  done
}

ensure_instance_volume() {
  local source_volume="${1:-}"
  local target_volume="${2:-}"
  [ -n "$source_volume" ] || return 1
  [ -n "$target_volume" ] || return 1
  if docker volume inspect "$target_volume" >/dev/null 2>&1; then
    return 0
  fi
  docker volume create "$target_volume" >/dev/null
  clone_volume_contents "$source_volume" "$target_volume"
}

volume_has_runtime_layout() {
  local target_volume="${1:-}"
  [ -n "$target_volume" ] || return 1
  docker volume inspect "$target_volume" >/dev/null 2>&1 || return 1
  docker run --rm \
    -e "MT5_ROOT_REL=${DOCKERMT_MT5_ROOT_REL}" \
    -e "MQL5_ROOT_REL=${DOCKERMT_MQL5_ROOT_REL}" \
    -v "${target_volume}:/config" \
    alpine sh -lc '
      set -eu
      [ -d "/config/${MT5_ROOT_REL}" ]
      [ -d "/config/${MQL5_ROOT_REL}" ]
    '
}

print_runtime_instances() {
  require_docker
  _print_cli_banner
  local rows found
  rows=""
  found=0
  while IFS= read -r runtime_name; do
    [ -n "$runtime_name" ] || continue
    local status image volume web_port telnet_port py_port last_accessed codex_session git_repos
    status="$(current_container_status "$runtime_name")"
    image="$(current_container_image "$runtime_name")"
    volume="$(current_container_config_volume "$runtime_name")"
    web_port="$(container_host_port "$runtime_name" "3000" "-")"
    telnet_port="$(container_host_port "$runtime_name" "1122" "-")"
    py_port="$(container_host_port "$runtime_name" "8001" "-")"
    IFS=$'\t' read -r last_accessed codex_session projects_count <<EOF3
$(project_summary_from_container "$runtime_name")
EOF3
    rows="${rows}$(printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s' "$runtime_name" "${status:-unknown}" "$web_port" "$telnet_port" "$py_port" "${volume:--}" "${last_accessed:--}" "${codex_session:--}" "${projects_count:-0}")"$'\n'
    found=1
  done <<EOF2
$(docker ps -a --format '{{.Names}}' | grep '^dockermt' | sort || true)
EOF2

  if [ "$found" -eq 0 ]; then
    echo "[dockermt] nenhuma instancia dockermt encontrada."
    return 0
  fi

  {
    printf 'NAME\tSTATUS\tWEB\tTELNET\tPYTHON\tCONFIG_VOLUME\tLAST_ACCESS\tCODEX_SESSION\tPROJECTS\n'
    printf '%s' "$rows"
  } | if command -v column >/dev/null 2>&1; then
        column -ts "$(printf '\t')"
      else
        cat
      fi
}

runtime_spawn() {
  require_docker
  _print_cli_banner
  local _spawn_step=0
  spawn_step() {
    _spawn_step=$((_spawn_step + 1))
    printf '[dockermt] instance-create[%s] %s\n' "$_spawn_step" "$1"
  }
  local raw_name=""
  local explicit_volume=""
  local explicit_snapshot=""
  local selected_banner_color=""
  local selected_banner_text_color=""
  local selected_runtime_user=""
  local selected_runtime_user_set=0
  local -a runtime_user_args=()
  local -a selected_indicators=()
  local -a selected_experts=()
  local -a selected_services=()
  local -a selected_includes=()
  local -a selected_libraries=()
  local -a selected_scripts=()
  local -a selected_files=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --volume)
        shift || true
        explicit_volume="${1:-}"
        ;;
      --volume=*)
        explicit_volume="${1#--volume=}"
        ;;
      --snapshot)
        shift || true
        explicit_snapshot="${1:-}"
        ;;
      --snapshot=*)
        explicit_snapshot="${1#--snapshot=}"
        ;;
      --color)
        shift || true
        selected_banner_color="${1:-}"
        ;;
      --color=*)
        selected_banner_color="${1#--color=}"
        ;;
      --text-color)
        shift || true
        selected_banner_text_color="${1:-}"
        ;;
      --text-color=*)
        selected_banner_text_color="${1#--text-color=}"
        ;;
      -u|--user)
        shift || true
        selected_runtime_user="${1:-}"
        selected_runtime_user_set=1
        ;;
      --user=*)
        selected_runtime_user="${1#--user=}"
        selected_runtime_user_set=1
        ;;
      --name)
        shift || true
        raw_name="${1:-}"
        ;;
      --name=*)
        raw_name="${1#--name=}"
        ;;
      --indicator)
        shift || true
        selected_indicators+=("${1:-}")
        ;;
      --indicator=*)
        selected_indicators+=("${1#--indicator=}")
        ;;
      --expert)
        shift || true
        selected_experts+=("${1:-}")
        ;;
      --expert=*)
        selected_experts+=("${1#--expert=}")
        ;;
      --service)
        shift || true
        selected_services+=("${1:-}")
        ;;
      --service=*)
        selected_services+=("${1#--service=}")
        ;;
      --include)
        shift || true
        selected_includes+=("${1:-}")
        ;;
      --include=*)
        selected_includes+=("${1#--include=}")
        ;;
      --library)
        shift || true
        selected_libraries+=("${1:-}")
        ;;
      --library=*)
        selected_libraries+=("${1#--library=}")
        ;;
      --script)
        shift || true
        selected_scripts+=("${1:-}")
        ;;
      --script=*)
        selected_scripts+=("${1#--script=}")
        ;;
      --files)
        shift || true
        selected_files+=("${1:-}")
        ;;
      --files=*)
        selected_files+=("${1#--files=}")
        ;;
      *)
        if [ -z "$raw_name" ]; then
          raw_name="$1"
        else
          echo "ERR: argumento inesperado em 'dockermt instance create': $1" >&2
          return 1
        fi
        ;;
    esac
    shift || true
  done

  if [ -z "$raw_name" ]; then
    echo "ERR: informe pelo menos o nome da instancia." >&2
    _instance_topic_usage create >&2
    return 1
  fi
  if [ "$selected_runtime_user_set" = "1" ] && [ -z "$selected_runtime_user" ]; then
    echo "ERR: informe um valor para --user (ex.: 0 ou 1000:1000)." >&2
    return 1
  fi
  if [ -n "$selected_runtime_user" ] && printf '%s' "$selected_runtime_user" | grep -Eq '[[:space:]]'; then
    echo "ERR: valor invalido em --user: nao use espacos." >&2
    return 1
  fi
  if [ -n "$selected_runtime_user" ]; then
    runtime_user_args=(--user "$selected_runtime_user")
  fi

  local safe_name current_name target_container source_image source_volume target_volume target_state_volume
  local has_requested_imports=0
  local snapshot_id ports telnet_port web_port py_port runtime_status
  local created_target_volume=0
  local import_announced=0
  local imports_summary=""
  safe_name="$(sanitize_snapshot_name "$raw_name")"
  current_name="$(resolve_current_runtime_container)"
  target_container="$(instance_container_name_from_slug "$safe_name")"
  target_state_volume="$(instance_state_volume_from_slug "$safe_name")"
  spawn_step "preparando..."

  source_image="$(preferred_runtime_image "$current_name")"
  source_volume="$(current_container_config_volume "$current_name")"
  [ -n "$source_image" ] || { echo "ERR: nao foi possivel localizar a imagem do runtime atual." >&2; return 1; }

  if [ -n "$explicit_snapshot" ]; then
    spawn_step "carregando snapshot..."
    snapshot_id="$(resolve_snapshot_id_from_input "$explicit_snapshot" 2>/dev/null || true)"
    [ -n "$snapshot_id" ] || { echo "ERR: snapshot nao localizado: $explicit_snapshot" >&2; return 1; }
    source_image="$(snapshot_image_ref_from_id "$snapshot_id")"
    source_volume="$(snapshot_volume_name_from_id "$snapshot_id")"
    docker image inspect "$source_image" >/dev/null 2>&1 || { echo "ERR: imagem de snapshot nao localizada: $source_image" >&2; return 1; }
    docker volume inspect "$source_volume" >/dev/null 2>&1 || { echo "ERR: volume de snapshot nao localizado: $source_volume" >&2; return 1; }
  fi

  if [ -n "$explicit_volume" ]; then
    target_volume="$explicit_volume"
  else
    target_volume="$(instance_volume_name_from_slug "$safe_name")"
  fi

  [ "${#selected_indicators[@]}" -eq 0 ] || imports_summary="${imports_summary} indicators=$(printf '%s,' "${selected_indicators[@]}" | sed 's/,$//')"
  [ "${#selected_experts[@]}" -eq 0 ] || imports_summary="${imports_summary} experts=$(printf '%s,' "${selected_experts[@]}" | sed 's/,$//')"
  [ "${#selected_services[@]}" -eq 0 ] || imports_summary="${imports_summary} services=$(printf '%s,' "${selected_services[@]}" | sed 's/,$//')"
  [ "${#selected_includes[@]}" -eq 0 ] || imports_summary="${imports_summary} include=$(printf '%s,' "${selected_includes[@]}" | sed 's/,$//')"
  [ "${#selected_libraries[@]}" -eq 0 ] || imports_summary="${imports_summary} libraries=$(printf '%s,' "${selected_libraries[@]}" | sed 's/,$//')"
  [ "${#selected_scripts[@]}" -eq 0 ] || imports_summary="${imports_summary} scripts=$(printf '%s,' "${selected_scripts[@]}" | sed 's/,$//')"
  [ "${#selected_files[@]}" -eq 0 ] || imports_summary="${imports_summary} files=$(printf '%s,' "${selected_files[@]}" | sed 's/,$//')"
  imports_summary="${imports_summary# }"
  if [ "${#selected_indicators[@]}" -ne 0 ] \
    || [ "${#selected_experts[@]}" -ne 0 ] \
    || [ "${#selected_services[@]}" -ne 0 ] \
    || [ "${#selected_includes[@]}" -ne 0 ] \
    || [ "${#selected_libraries[@]}" -ne 0 ] \
    || [ "${#selected_scripts[@]}" -ne 0 ] \
    || [ "${#selected_files[@]}" -ne 0 ]; then
    has_requested_imports=1
  fi
  if [ "$has_requested_imports" = "1" ] && [ -z "$source_volume" ]; then
    echo "ERR: nao foi possivel localizar o volume /config base para importar os itens solicitados." >&2
    return 1
  fi
  if [ -n "$selected_banner_color" ]; then
    valid_instance_banner_color "$selected_banner_color" || {
      echo "ERR: cor de instancia invalida: $selected_banner_color" >&2
      echo "Use: blue, cyan, green, magenta, red, yellow ou gray." >&2
      return 1
    }
  fi
  if [ -n "$selected_banner_text_color" ]; then
    valid_instance_banner_text_color "$selected_banner_text_color" || {
      echo "ERR: cor de texto invalida: $selected_banner_text_color" >&2
      echo "Use: black, white, yellow, cyan, blue, magenta, red, green, gray, gold ou amber." >&2
      return 1
    }
  fi

  if ! docker volume inspect "$target_volume" >/dev/null 2>&1; then
    spawn_step "criando volume de instancia..."
    docker volume create "$target_volume" >/dev/null
    created_target_volume=1
  fi
  if ! volume_has_runtime_layout "$target_volume"; then
    spawn_step "preparando base de instancia..."
    created_target_volume=1
  fi

  if [ "$created_target_volume" = "1" ]; then
    spawn_step "limpando workspace..."
    reset_target_workspace_from_zero "$target_volume"
    spawn_step "aplicando imports..."
    if [ "${#selected_indicators[@]}" -ne 0 ]; then
      if [ "$import_announced" -eq 0 ]; then
        spawn_step "importando recursos..."
        import_announced=1
      fi
      copy_selected_mql5_items_into_volume "$source_volume" "$target_volume" "Indicators" "${selected_indicators[@]}"
    fi
    if [ "${#selected_experts[@]}" -ne 0 ]; then
      if [ "$import_announced" -eq 0 ]; then
        spawn_step "importando recursos..."
        import_announced=1
      fi
      copy_selected_mql5_items_into_volume "$source_volume" "$target_volume" "Experts" "${selected_experts[@]}"
    fi
    if [ "${#selected_services[@]}" -ne 0 ]; then
      if [ "$import_announced" -eq 0 ]; then
        spawn_step "importando recursos..."
        import_announced=1
      fi
      copy_selected_mql5_items_into_volume "$source_volume" "$target_volume" "Services" "${selected_services[@]}"
    fi
    if [ "${#selected_includes[@]}" -ne 0 ]; then
      if [ "$import_announced" -eq 0 ]; then
        spawn_step "importando recursos..."
        import_announced=1
      fi
      copy_selected_mql5_items_into_volume "$source_volume" "$target_volume" "Include" "${selected_includes[@]}"
    fi
    if [ "${#selected_libraries[@]}" -ne 0 ]; then
      if [ "$import_announced" -eq 0 ]; then
        spawn_step "importando recursos..."
        import_announced=1
      fi
      copy_selected_mql5_items_into_volume "$source_volume" "$target_volume" "Libraries" "${selected_libraries[@]}"
    fi
    if [ "${#selected_scripts[@]}" -ne 0 ]; then
      if [ "$import_announced" -eq 0 ]; then
        spawn_step "importando recursos..."
        import_announced=1
      fi
      copy_selected_mql5_items_into_volume "$source_volume" "$target_volume" "Scripts" "${selected_scripts[@]}"
    fi
    if [ "${#selected_files[@]}" -ne 0 ]; then
      if [ "$import_announced" -eq 0 ]; then
        spawn_step "importando recursos..."
        import_announced=1
      fi
      copy_selected_mql5_items_into_volume "$source_volume" "$target_volume" "Files" "${selected_files[@]}"
    fi
    spawn_step "preparando projeto..."
    prepare_codex_layout_in_volume "$target_volume" "$safe_name" fresh
  else
    spawn_step "reutilizando volume..."
    prepare_codex_layout_in_volume "$target_volume" "$safe_name" reuse
  fi
  spawn_step "sincronizando recursos..."
  sync_codex_docs_into_volume "$target_volume"
  sync_codex_auth_into_volume "$target_volume"

  docker volume inspect "$target_state_volume" >/dev/null 2>&1 || docker volume create "$target_state_volume" >/dev/null

  if container_exists "$target_container"; then
    if [ -n "$selected_runtime_user" ]; then
      echo "[dockermt] aviso: instancia ja existe; --user so vale na primeira criacao do container."
    fi
    runtime_status="$(current_container_status "$target_container")"
    if [ "$runtime_status" != "running" ]; then
      spawn_step "subindo..."
      docker start "$target_container" >/dev/null
    fi
  else
    spawn_step "alocando portas..."
    ports="$(allocate_instance_ports)" || { echo "ERR: nao foi possivel reservar portas livres para a nova instancia." >&2; return 1; }
    IFS='|' read -r telnet_port web_port py_port <<EOF2
$ports
EOF2
    spawn_step "criando container..."
    docker run -d \
      --name "$target_container" \
      --hostname "$target_container" \
      --gpus all \
      "${runtime_user_args[@]}" \
      -e "TITLE=DockerMT [$safe_name]" \
      -e "DOCKERMT_CONTAINER_NAME=$target_container" \
      -e "DOCKERMT_INSTANCE_NAME=$safe_name" \
      -e "DOCKERMT_STATE_VOLUME=$target_state_volume" \
      -e "TELNETMT_PORT=1122" \
      -e "MT5_WEB_PORT=3000" \
      -e "MT5_PY_PORT=8001" \
      -e "DOCKERMT_HOST_TELNET_PORT=$telnet_port" \
      -e "DOCKERMT_HOST_WEB_PORT=$web_port" \
      -e "DOCKERMT_HOST_PY_PORT=$py_port" \
      -e "DOCKERMT_SNAPSHOT_REPO=$SNAPSHOT_REPO" \
      -e "DOCKERMT_SNAPSHOT_VOLUME_PREFIX=$SNAPSHOT_VOLUME_PREFIX" \
      -e "DOCKERMT_PULL_REPO=$PULL_REPO" \
      -e "DOCKERMT_DOCKER_SOCKET_PATH=$DOCKER_SOCKET_PATH" \
      -v "${target_volume}:/config" \
      -v "${DOCKER_SOCKET_PATH}:${DOCKER_SOCKET_PATH}" \
      -p "${telnet_port}:1122" \
      -p "${web_port}:3000" \
      -p "${py_port}:8001" \
      --label "dockermt.role=instance" \
      --label "dockermt.instance.name=$safe_name" \
      --label "dockermt.node.role=instance" \
      --label "dockermt.node.name=$safe_name" \
      --label "dockermt.node.parent=$current_name" \
      --label "dockermt.runtime=1" \
      --label "dockermt.runtime.name=$safe_name" \
      --label "dockermt.runtime.parent=$current_name" \
      --label "dockermt.runtime.config-volume=$target_volume" \
      "$source_image" >/dev/null
  fi

  spawn_step "atualizando runtime..."
  local runtime_src_dockermt="/usr/local/bin/dockermt"
  local runtime_src_shell="/usr/local/bin/dockermt-instance-shell"
  local runtime_src_args="/opt/dockermt-full/dist/lib/args.js"
  local runtime_src_dispatch="/opt/dockermt-full/dist/lib/dispatch.js"
  if [ -f /config/.dockermt/patches/runtime/dockermt ]; then
    runtime_src_dockermt="/config/.dockermt/patches/runtime/dockermt"
  fi
  if [ -f /config/.dockermt/patches/runtime/dockermt-instance-shell ]; then
    runtime_src_shell="/config/.dockermt/patches/runtime/dockermt-instance-shell"
  fi
  if [ -f /config/.dockermt/patches/runtime/args.js ]; then
    runtime_src_args="/config/.dockermt/patches/runtime/args.js"
  fi
  if [ -f /config/.dockermt/patches/runtime/dispatch.js ]; then
    runtime_src_dispatch="/config/.dockermt/patches/runtime/dispatch.js"
  fi
  docker cp "$runtime_src_dockermt" "${target_container}:/usr/local/bin/dockermt"
  if [ -f "$runtime_src_shell" ]; then
    docker cp "$runtime_src_shell" "${target_container}:/usr/local/bin/dockermt-instance-shell"
  fi
  if [ -f "$runtime_src_args" ]; then
    docker cp "$runtime_src_args" "${target_container}:/opt/dockermt-full/dist/lib/args.js"
  fi
  if [ -f "$runtime_src_dispatch" ]; then
    docker cp "$runtime_src_dispatch" "${target_container}:/opt/dockermt-full/dist/lib/dispatch.js"
  fi
  docker exec "$target_container" sh -lc 'chmod 755 /usr/local/bin/dockermt /usr/local/bin/dockermt-instance-shell 2>/dev/null || true'

  docker exec "$target_container" /usr/local/bin/dockermt-project-meta init >/dev/null 2>&1 || true
  record_project_import_batch "$target_container" "Indicators" "${selected_indicators[@]}"
  record_project_import_batch "$target_container" "Experts" "${selected_experts[@]}"
  record_project_import_batch "$target_container" "Services" "${selected_services[@]}"
  record_project_import_batch "$target_container" "Include" "${selected_includes[@]}"
  record_project_import_batch "$target_container" "Libraries" "${selected_libraries[@]}"
  record_project_import_batch "$target_container" "Scripts" "${selected_scripts[@]}"
  record_project_import_batch "$target_container" "Files" "${selected_files[@]}"

  if [ "$created_target_volume" = "1" ] || [ -n "$selected_banner_color" ] || [ -n "$selected_banner_text_color" ]; then
    spawn_step "aplicando tema..."
    assign_instance_banner_theme "$target_volume" "$safe_name" "$(current_container_image "$target_container")" "$selected_banner_color" "$selected_banner_text_color"
  fi
  spawn_step "finalizando..."
  rename_instance_mt5_window_in_container "$target_container" ":1" "$safe_name" >/dev/null 2>&1 || true

  cat <<EOF2
[dockermt] instancia pronta.
container    : $target_container
image        : $(current_container_image "$target_container")
config-volume: $(current_container_config_volume "$target_container")
state-volume : $target_state_volume
workspace    : $( [ "$created_target_volume" = "1" ] && printf 'factory' || printf 'existente' )
imports      : $( [ -n "$imports_summary" ] && printf '%s' "$imports_summary" || printf 'nenhum' )
project      : /config/.dockermt/codex/session/project
projects     : dockermt @$safe_name project
url          : $(runtime_web_url "$target_container")
telnet       : $(container_host_port "$target_container" "1122" "-")
python       : $(container_host_port "$target_container" "8001" "-")
theme        : $( [ -n "$selected_banner_color" ] && printf '%s/%s' "$selected_banner_color" "${selected_banner_text_color:-auto}" || printf 'auto' )
prompt       : dockermt @$safe_name ...
shell        : dockermt @$safe_name shell
open         : dockermt @$safe_name container open
status       : dockermt @$safe_name container status
EOF2

  (
    docker exec "$target_container" /usr/local/bin/dockermt container open >/dev/null 2>&1 || true
  ) &
}

runtime_import_named() {
  local target_container="${1:-}"
  local target_key="${2:-}"
  shift 2 || true
  [ -n "$target_container" ] || { echo "ERR: instancia alvo ausente para import." >&2; return 1; }

  local -a selected_indicators=()
  local -a selected_experts=()
  local -a selected_services=()
  local -a selected_includes=()
  local -a selected_libraries=()
  local -a selected_scripts=()
  local -a selected_files=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --indicator)
        shift || true
        selected_indicators+=("${1:-}")
        ;;
      --indicator=*)
        selected_indicators+=("${1#--indicator=}")
        ;;
      --expert)
        shift || true
        selected_experts+=("${1:-}")
        ;;
      --expert=*)
        selected_experts+=("${1#--expert=}")
        ;;
      --service)
        shift || true
        selected_services+=("${1:-}")
        ;;
      --service=*)
        selected_services+=("${1#--service=}")
        ;;
      --include)
        shift || true
        selected_includes+=("${1:-}")
        ;;
      --include=*)
        selected_includes+=("${1#--include=}")
        ;;
      --library)
        shift || true
        selected_libraries+=("${1:-}")
        ;;
      --library=*)
        selected_libraries+=("${1#--library=}")
        ;;
      --script)
        shift || true
        selected_scripts+=("${1:-}")
        ;;
      --script=*)
        selected_scripts+=("${1#--script=}")
        ;;
      --files)
        shift || true
        selected_files+=("${1:-}")
        ;;
      --files=*)
        selected_files+=("${1#--files=}")
        ;;
      *)
        echo "ERR: argumento inesperado em 'dockermt @${target_key} import': $1" >&2
        return 1
        ;;
    esac
    shift || true
  done

  if [ "${#selected_indicators[@]}" -eq 0 ] \
    && [ "${#selected_experts[@]}" -eq 0 ] \
    && [ "${#selected_services[@]}" -eq 0 ] \
    && [ "${#selected_includes[@]}" -eq 0 ] \
    && [ "${#selected_libraries[@]}" -eq 0 ] \
    && [ "${#selected_scripts[@]}" -eq 0 ] \
    && [ "${#selected_files[@]}" -eq 0 ]; then
    echo "ERR: informe ao menos um item para importar." >&2
    echo "Use: dockermt @${target_key} import --indicator NOME, --expert NOME ou --service NOME" >&2
    return 1
  fi

  local current_name source_volume target_volume imports_summary=""
  current_name="$(resolve_current_runtime_container)"
  source_volume="$(current_container_config_volume "$current_name")"
  target_volume="$(current_container_config_volume "$target_container")"
  [ -n "$source_volume" ] || { echo "ERR: nao foi possivel localizar o volume fonte atual." >&2; return 1; }
  [ -n "$target_volume" ] || { echo "ERR: nao foi possivel localizar o volume da instancia alvo." >&2; return 1; }

  if [ "$source_volume" = "$target_volume" ]; then
    echo "ERR: a instancia alvo usa o mesmo volume da instancia atual; import aqui seria redundante." >&2
    return 1
  fi

  if [ "${#selected_indicators[@]}" -ne 0 ]; then
    copy_selected_mql5_items_into_volume "$source_volume" "$target_volume" "Indicators" "${selected_indicators[@]}" || return 1
  fi
  if [ "${#selected_experts[@]}" -ne 0 ]; then
    copy_selected_mql5_items_into_volume "$source_volume" "$target_volume" "Experts" "${selected_experts[@]}" || return 1
  fi
  if [ "${#selected_services[@]}" -ne 0 ]; then
    copy_selected_mql5_items_into_volume "$source_volume" "$target_volume" "Services" "${selected_services[@]}" || return 1
  fi
  if [ "${#selected_includes[@]}" -ne 0 ]; then
    copy_selected_mql5_items_into_volume "$source_volume" "$target_volume" "Include" "${selected_includes[@]}" || return 1
  fi
  if [ "${#selected_libraries[@]}" -ne 0 ]; then
    copy_selected_mql5_items_into_volume "$source_volume" "$target_volume" "Libraries" "${selected_libraries[@]}" || return 1
  fi
  if [ "${#selected_scripts[@]}" -ne 0 ]; then
    copy_selected_mql5_items_into_volume "$source_volume" "$target_volume" "Scripts" "${selected_scripts[@]}" || return 1
  fi
  if [ "${#selected_files[@]}" -ne 0 ]; then
    copy_selected_mql5_items_into_volume "$source_volume" "$target_volume" "Files" "${selected_files[@]}" || return 1
  fi

  docker exec "$target_container" /usr/local/bin/dockermt-project-meta init >/dev/null 2>&1 || true
  record_project_import_batch "$target_container" "Indicators" "${selected_indicators[@]}"
  record_project_import_batch "$target_container" "Experts" "${selected_experts[@]}"
  record_project_import_batch "$target_container" "Services" "${selected_services[@]}"
  record_project_import_batch "$target_container" "Include" "${selected_includes[@]}"
  record_project_import_batch "$target_container" "Libraries" "${selected_libraries[@]}"
  record_project_import_batch "$target_container" "Scripts" "${selected_scripts[@]}"
  record_project_import_batch "$target_container" "Files" "${selected_files[@]}"

  [ "${#selected_indicators[@]}" -eq 0 ] || imports_summary="${imports_summary} indicators=$(printf '%s,' "${selected_indicators[@]}" | sed 's/,$//')"
  [ "${#selected_experts[@]}" -eq 0 ] || imports_summary="${imports_summary} experts=$(printf '%s,' "${selected_experts[@]}" | sed 's/,$//')"
  [ "${#selected_services[@]}" -eq 0 ] || imports_summary="${imports_summary} services=$(printf '%s,' "${selected_services[@]}" | sed 's/,$//')"
  [ "${#selected_includes[@]}" -eq 0 ] || imports_summary="${imports_summary} include=$(printf '%s,' "${selected_includes[@]}" | sed 's/,$//')"
  [ "${#selected_libraries[@]}" -eq 0 ] || imports_summary="${imports_summary} libraries=$(printf '%s,' "${selected_libraries[@]}" | sed 's/,$//')"
  [ "${#selected_scripts[@]}" -eq 0 ] || imports_summary="${imports_summary} scripts=$(printf '%s,' "${selected_scripts[@]}" | sed 's/,$//')"
  [ "${#selected_files[@]}" -eq 0 ] || imports_summary="${imports_summary} files=$(printf '%s,' "${selected_files[@]}" | sed 's/,$//')"
  imports_summary="${imports_summary# }"

  cat <<EOF2
[dockermt] import concluido.
instance     : ${target_container}
config-volume: ${target_volume}
imports      : ${imports_summary}
projects     : dockermt @${target_key} project
shell        : dockermt @${target_key} shell
open         : dockermt @${target_key} container open
EOF2
}

runtime_save_alias() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    name="$(date -u +dockermt-review-%Y%m%dT%H%M%SZ)"
  fi
  snapshot_commit -m "$name" -n "$name"
}

runtime_restore_alias() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    echo "ERR: uso: dockermt container restore <estado>" >&2
    exit 1
  fi
  snapshot_select "$name"
}

current_container_snapshot_id() {
  local ref
  ref="$(current_container_image)"
  [ -n "$ref" ] || return 0
  docker image inspect "$ref" --format '{{index .Config.Labels "dockermt.snapshot.id"}}' 2>/dev/null || true
}

snapshot_id_from_image_ref() {
  local ref="${1:-}"
  [ -n "$ref" ] || return 1
  docker image inspect "$ref" --format '{{index .Config.Labels "dockermt.snapshot.id"}}' 2>/dev/null | awk 'NF && $0 != "<no value>" {print; found=1} END{exit(found?0:1)}'
}

resolve_snapshot_id_from_input() {
  local raw="${1:-}"
  local ref snapshot_id
  if [ -z "$raw" ]; then
    snapshot_id="$(selected_snapshot_id)"
    [ -n "$snapshot_id" ] || snapshot_id="$(latest_snapshot_id)"
    [ -n "$snapshot_id" ] || return 1
    printf '%s\n' "$snapshot_id"
    return 0
  fi

  ref="$(snapshot_image_ref_from_id "$raw")"
  if snapshot_id="$(snapshot_id_from_image_ref "$ref" 2>/dev/null)"; then
    printf '%s\n' "$snapshot_id"
    return 0
  fi
  if snapshot_id="$(snapshot_id_from_image_ref "$raw" 2>/dev/null)"; then
    printf '%s\n' "$snapshot_id"
    return 0
  fi
  ref="$(resolve_pull_image_ref "$raw" 2>/dev/null || true)"
  if [ -n "$ref" ] && snapshot_id="$(snapshot_id_from_image_ref "$ref" 2>/dev/null)"; then
    printf '%s\n' "$snapshot_id"
    return 0
  fi
  return 1
}

next_snapshot_version() {
  local safe_name="$1"
  local current
  current="$({ docker image ls "$SNAPSHOT_REPO" --format '{{.Tag}}' 2>/dev/null || true; } |
    sed -n "s/^${safe_name}\.v\([0-9][0-9]*\)-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9][0-9][0-9]$/\1/p" |
    sort -n |
    tail -n 1)"
  if [ -z "$current" ]; then
    printf '1\n'
    return 0
  fi
  printf '%s\n' "$((current + 1))"
}

named_snapshot_rows() {
  local safe_name="$1"
  docker image ls "$SNAPSHOT_REPO" --format '{{.Repository}}:{{.Tag}}' 2>/dev/null | while read -r ref; do
    [ -n "$ref" ] || continue
    local inspect_out snapshot_name snapshot_version snapshot_timestamp snapshot_id volume_name
    inspect_out="$(docker image inspect "$ref" --format '{{index .Config.Labels "dockermt.snapshot.name"}}|{{index .Config.Labels "dockermt.snapshot.version"}}|{{index .Config.Labels "dockermt.snapshot.timestamp"}}|{{index .Config.Labels "dockermt.snapshot.id"}}' 2>/dev/null || true)"
    snapshot_name="$(printf '%s' "$inspect_out" | cut -d'|' -f1)"
    snapshot_version="$(printf '%s' "$inspect_out" | cut -d'|' -f2)"
    snapshot_timestamp="$(printf '%s' "$inspect_out" | cut -d'|' -f3)"
    snapshot_id="$(printf '%s' "$inspect_out" | cut -d'|' -f4)"
    if [ "$snapshot_name" != "$safe_name" ] || [ -z "$snapshot_id" ] || [ "$snapshot_id" = "<no value>" ]; then
      continue
    fi
    volume_name="$(snapshot_volume_name_from_id "$snapshot_id")"
    printf '%s|%s|%s|%s|%s\n' "$snapshot_id" "$snapshot_version" "$snapshot_timestamp" "$ref" "$volume_name"
  done | sort -t'|' -k3,3
}

snapshot_count_for_name() {
  local safe_name="$1"
  local count=0
  while IFS= read -r _row; do
    [ -n "$_row" ] || continue
    count=$((count + 1))
  done <<EOF2
$(named_snapshot_rows "$safe_name")
EOF2
  printf '%s\n' "$count"
}

delete_snapshot_local() {
  local snapshot_id="$1"
  local image_ref volume_name selected_id
  image_ref="$(snapshot_image_ref_from_id "$snapshot_id")"
  volume_name="$(snapshot_volume_name_from_id "$snapshot_id")"
  selected_id="$(selected_snapshot_id)"
  if [ "$selected_id" = "$snapshot_id" ]; then
    clear_selected_snapshot_id
  fi
  docker image rm -f "$image_ref" >/dev/null 2>&1 || true
  docker volume rm "$volume_name" >/dev/null 2>&1 || true
}

prune_named_snapshots() {
  local safe_name="$1"
  local keep_snapshot_id="${2:-}"
  local count deleted prune_snapshot_id
  count="$(snapshot_count_for_name "$safe_name")"
  if [ "$count" -le "$MAX_SNAPSHOTS_PER_NAME" ]; then
    return 0
  fi

  deleted=0
  while IFS='|' read -r prune_snapshot_id _snapshot_version _snapshot_timestamp _image_ref _volume_name; do
    [ -n "$prune_snapshot_id" ] || continue
    if [ -n "$keep_snapshot_id" ] && [ "$prune_snapshot_id" = "$keep_snapshot_id" ]; then
      continue
    fi
    if [ "$count" -le "$MAX_SNAPSHOTS_PER_NAME" ]; then
      break
    fi
    echo "[dockermt] removendo snapshot antigo para manter o limite de ${MAX_SNAPSHOTS_PER_NAME}: $prune_snapshot_id"
    delete_snapshot_local "$prune_snapshot_id"
    count=$((count - 1))
    deleted=$((deleted + 1))
  done <<EOF2
$(named_snapshot_rows "$safe_name")
EOF2

  if [ "$count" -gt "$MAX_SNAPSHOTS_PER_NAME" ]; then
    echo "WARN: alguns snapshots antigos ainda nao puderam ser removidos; sera necessario recriar o runtime e repetir a limpeza." >&2
  fi
}

print_snapshots() {
  local current_image current_volume latest_id latest_image latest_volume selected_id selected_image selected_volume rows found
  current_image="$(current_container_image)"
  current_volume="$(current_container_config_volume)"
  latest_id="$(latest_snapshot_id)"
  latest_image=""
  latest_volume=""
  selected_id="$(selected_snapshot_id)"
  selected_image=""
  selected_volume=""
  rows=""
  found=0

  if [ -n "$latest_id" ]; then
    latest_image="$(snapshot_image_ref_from_id "$latest_id")"
    latest_volume="$(snapshot_volume_name_from_id "$latest_id")"
  fi
  if [ -n "$selected_id" ]; then
    selected_image="$(snapshot_image_ref_from_id "$selected_id")"
    selected_volume="$(snapshot_volume_name_from_id "$selected_id")"
  fi

  while IFS= read -r ref; do
    [ -n "$ref" ] || continue
    local inspect_out snapshot_id timestamp message volume_name active_mark selected_mark latest_mark
    inspect_out="$(docker image inspect "$ref" --format '{{index .Config.Labels "dockermt.snapshot.timestamp"}}|{{index .Config.Labels "dockermt.snapshot.id"}}|{{.Comment}}' 2>/dev/null || true)"
    snapshot_id="$(printf '%s' "$inspect_out" | cut -d'|' -f2)"
    timestamp="$(printf '%s' "$inspect_out" | cut -d'|' -f1)"
    message="$(printf '%s' "$inspect_out" | cut -d'|' -f3- | tr '\t\r\n' '   ')"
    if [ -z "$snapshot_id" ] || [ "$snapshot_id" = "<no value>" ] || [ -z "$timestamp" ] || [ "$timestamp" = "<no value>" ]; then
      continue
    fi
    volume_name="$(snapshot_volume_name_from_id "$snapshot_id")"
    active_mark=""
    selected_mark=""
    latest_mark=""
    if [ "$ref" = "$current_image" ] && [ "$volume_name" = "$current_volume" ]; then
      active_mark="*"
    fi
    if [ "$ref" = "$selected_image" ] && [ "$volume_name" = "$selected_volume" ]; then
      selected_mark="*"
    fi
    if [ "$ref" = "$latest_image" ] && [ "$volume_name" = "$latest_volume" ]; then
      latest_mark="*"
    fi
    rows="${rows}$(printf '%s\t%s\t%s\t%s\t%s\t%s\t%s' "$active_mark" "$selected_mark" "$latest_mark" "$snapshot_id" "$ref" "$volume_name" "${message:--}")"$'\n'
    found=1
  done <<EOF2
$(docker image ls "$SNAPSHOT_REPO" --format '{{.Repository}}:{{.Tag}}' 2>/dev/null)
EOF2

  if [ "$found" -eq 0 ]; then
    echo "[dockermt] nenhum snapshot encontrado em '$SNAPSHOT_REPO'."
    return 0
  fi

  {
    printf 'ACTIVE\tSELECTED\tLATEST\tSNAPSHOT\tIMAGE\tVOLUME\tMESSAGE\n'
    printf '%s' "$rows" | sort -r -k4,4
  } | if command -v column >/dev/null 2>&1; then
        column -ts "$(printf '\t')"
      else
        cat
      fi
}

snapshot_commit() {
  require_docker
  local message=""
  local raw_name="snapshot"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -m|--message)
        shift
        [ "$#" -gt 0 ] || { echo "ERR: faltou texto para -m/--message." >&2; return 1; }
        message="$1"
        ;;
      -n|--name)
        shift
        [ "$#" -gt 0 ] || { echo "ERR: faltou texto para -n/--name." >&2; return 1; }
        raw_name="$1"
        ;;
      *)
        echo "ERR: flag desconhecida em container commit: $1" >&2
        return 1
        ;;
    esac
    shift
  done

  if [ -z "$message" ]; then
    echo "ERR: informe -m 'mensagem'." >&2
    return 1
  fi

  local safe_name timestamp version snapshot_id image_ref source_volume target_volume source_image
  safe_name="$(sanitize_snapshot_name "$raw_name")"
  timestamp="$(date +%Y%m%d-%H%M%S)"
  local current_runtime_name
  current_runtime_name="$(resolve_current_runtime_container)"
  source_volume="$(current_container_config_volume "$current_runtime_name")"
  source_image="$(current_container_image "$current_runtime_name")"
  version="$(next_snapshot_version "$safe_name")"
  snapshot_id="$(build_snapshot_id "$safe_name" "$version" "$timestamp")"
  image_ref="$(snapshot_image_ref_from_id "$snapshot_id")"
  target_volume="$(snapshot_volume_name_from_id "$snapshot_id")"

  if [ -z "$source_volume" ]; then
    echo "ERR: nao foi possivel localizar o volume /config do container '$current_runtime_name'." >&2
    return 1
  fi
  if docker image inspect "$image_ref" >/dev/null 2>&1; then
    echo "ERR: imagem '$image_ref' ja existe." >&2
    return 1
  fi
  if docker volume inspect "$target_volume" >/dev/null 2>&1; then
    echo "ERR: volume '$target_volume' ja existe." >&2
    return 1
  fi

  echo "[dockermt] criando snapshot da imagem: $image_ref"
  docker commit --pause=false \
    -m "$message" \
    --change "LABEL dockermt.snapshot.id=$snapshot_id" \
    --change "LABEL dockermt.snapshot.name=$safe_name" \
    --change "LABEL dockermt.snapshot.version=$version" \
    --change "LABEL dockermt.snapshot.timestamp=$timestamp" \
    --change "LABEL dockermt.snapshot.source_image=$source_image" \
    --change "LABEL dockermt.snapshot.source_volume=$source_volume" \
    "$current_runtime_name" "$image_ref" >/dev/null

  echo "[dockermt] clonando volume '$source_volume' para '$target_volume'..."
  docker volume create \
    --label "dockermt.snapshot.id=$snapshot_id" \
    --label "dockermt.snapshot.name=$safe_name" \
    --label "dockermt.snapshot.version=$version" \
    --label "dockermt.snapshot.timestamp=$timestamp" \
    --label "dockermt.snapshot.image=$image_ref" \
    "$target_volume" >/dev/null
  docker run --rm -v "${source_volume}:/from:ro" -v "${target_volume}:/to" alpine sh -lc \
    'cd /from && tar cf - . | (cd /to && tar xf -)'

  set_selected_snapshot_id "$snapshot_id"
  prune_named_snapshots "$safe_name" "$snapshot_id"

  cat <<EOF2
[dockermt] snapshot salvo.
snapshot_id : $snapshot_id
image       : $image_ref
volume      : $target_volume
message     : $message
EOF2
}

snapshot_pull() {
  require_docker
  local raw_ref="${1:-}"
  local remote_ref snapshot_id local_ref target_volume
  if [ -z "$raw_ref" ]; then
    echo "ERR: informe o nome/tag da imagem. Ex.: dockermt container pull paradigm-3.0.v4-20260310-071305" >&2
    return 1
  fi
  remote_ref="$(resolve_pull_image_ref "$raw_ref")" || {
    echo "ERR: nao foi possivel resolver a imagem para pull." >&2
    return 1
  }

  echo "[dockermt] baixando imagem: $remote_ref"
  docker pull "$remote_ref"

  snapshot_id="$(docker image inspect "$remote_ref" --format '{{index .Config.Labels "dockermt.snapshot.id"}}' 2>/dev/null || true)"
  if [ -z "$snapshot_id" ] || [ "$snapshot_id" = "<no value>" ]; then
    echo "ERR: a imagem '$remote_ref' nao contem metadados de snapshot." >&2
    return 1
  fi

  local_ref="$(snapshot_image_ref_from_id "$snapshot_id")"
  docker tag "$remote_ref" "$local_ref"

  target_volume="$(snapshot_volume_name_from_id "$snapshot_id")"
  if docker volume inspect "$target_volume" >/dev/null 2>&1; then
    echo "[dockermt] volume vinculado ja existe: $target_volume"
  else
    echo "[dockermt] criando volume vinculado: $target_volume"
    docker volume create \
      --label "dockermt.snapshot.id=$snapshot_id" \
      --label "dockermt.snapshot.image=$local_ref" \
      "$target_volume" >/dev/null
    echo "[dockermt] nenhum backup local do volume foi encontrado; o volume vinculado foi criado vazio."
  fi

  set_selected_snapshot_id "$snapshot_id"

  cat <<EOF2
[dockermt] snapshot importado.
snapshot_id : $snapshot_id
remote      : $remote_ref
image       : $local_ref
volume      : $target_volume
EOF2
}

snapshot_push() {
  require_docker
  local raw_ref="${1:-}"
  local snapshot_id local_ref remote_ref
  snapshot_id="$(resolve_snapshot_id_from_input "$raw_ref" 2>/dev/null || true)"
  if [ -z "$snapshot_id" ]; then
    echo "ERR: nao foi possivel localizar o snapshot para push." >&2
    return 1
  fi
  local_ref="$(snapshot_image_ref_from_id "$snapshot_id")"
  if ! docker image inspect "$local_ref" >/dev/null 2>&1; then
    echo "ERR: imagem local '$local_ref' nao encontrada." >&2
    return 1
  fi
  remote_ref="${PULL_REPO}:$snapshot_id"
  docker tag "$local_ref" "$remote_ref"
  echo "[dockermt] publicando imagem: $remote_ref"
  docker push "$remote_ref"
  cat <<EOF2
[dockermt] snapshot publicado.
snapshot_id : $snapshot_id
image       : $local_ref
remote      : $remote_ref
EOF2
}

dukascopy_sync() {
  if ! command -v node >/dev/null 2>&1; then
    echo "ERR: node nao encontrado no container." >&2
    return 127
  fi
  if [ ! -f "$DUKASCOPY_SCRIPT_PATH" ]; then
    echo "ERR: script privado da Dukascopy nao encontrado em '$DUKASCOPY_SCRIPT_PATH'." >&2
    return 1
  fi

  local json_output
  json_output="$(node "$DUKASCOPY_SCRIPT_PATH" mail --quiet --no-debug --json --all-valid)"

  JSON_INPUT="$json_output" python3 - "$DUKASCOPY_STATE_FILE" "$DUKASCOPY_ENV_FILE" "$MT5_COMMON_INI_PATH" <<'PY'
import json
import os
import pathlib
import sys
from datetime import datetime

state_path = pathlib.Path(sys.argv[1])
env_path = pathlib.Path(sys.argv[2])
common_ini_path = pathlib.Path(sys.argv[3])
raw = os.environ.get("JSON_INPUT", "").strip()

if not raw:
    print("ERR: o executavel privado da Dukascopy nao retornou JSON.", file=sys.stderr)
    sys.exit(1)

try:
    payload = json.loads(raw)
except json.JSONDecodeError as exc:
    print(f"ERR: JSON invalido retornado pelo executavel privado: {exc}", file=sys.stderr)
    sys.exit(1)

credentials = payload.get("credentials") or []
valid_credentials = [c for c in credentials if c.get("valid")]
if not valid_credentials:
    print("ERR: nenhuma credencial valida foi encontrada no lookback atual.", file=sys.stderr)
    sys.exit(1)

def remaining_ms(item):
    try:
        return int(item.get("remainingMs", 0))
    except Exception:
        return 0

best = {}
for kind in ("mt5", "jforex", "mt4"):
    subset = [item for item in valid_credentials if item.get("kind") == kind]
    if subset:
        best[kind] = max(subset, key=remaining_ms)

if "mt5" not in best:
    print("ERR: nenhuma credencial valida de MetaTrader 5 foi encontrada.", file=sys.stderr)
    sys.exit(1)

primary = best["mt5"]
mt5_valid_credentials = [item for item in valid_credentials if item.get("kind") == "mt5"]

state_payload = {
    "syncedAt": datetime.utcnow().replace(microsecond=0).isoformat() + "Z",
    "source": {
        "generatedAt": payload.get("generatedAt"),
        "count": payload.get("count", len(credentials)),
        "validCount": len(mt5_valid_credentials),
    },
    "primaryKind": "mt5",
    "primary": primary,
    "selected": {"mt5": primary},
    "allValid": mt5_valid_credentials,
    "notes": [
        "A credencial operacional do sync e sempre a do MetaTrader 5.",
        "MT5 common.ini recebeu Login, Server, Password e KeepPrivate=1.",
        "O campo Environment do common.ini foi limpo para o proprio MT5 regravar a credencial cifrada.",
    ],
}

state_path.parent.mkdir(parents=True, exist_ok=True)
state_path.write_text(json.dumps(state_payload, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")

with env_path.open("w", encoding="utf-8") as fh:
    fh.write("# Gerado por: dockermt dukascopy sync\n")
    fh.write("DUKASCOPY_PRIMARY_KIND=\"mt5\"\n")
    fh.write(f"DUKASCOPY_LOGIN={json.dumps(primary.get('login', ''))}\n")
    fh.write(f"DUKASCOPY_PASSWORD={json.dumps(primary.get('password', ''))}\n")
    if primary.get("server"):
        fh.write(f"DUKASCOPY_SERVER={json.dumps(primary.get('server', ''))}\n")
    fh.write(f"DUKASCOPY_EXPIRES_AT={json.dumps(primary.get('expiresAt', ''))}\n")
    fh.write(f"DUKASCOPY_REMAINING_MS={json.dumps(str(primary.get('remainingMs', 0)))}\n")
    fh.write(f"DUKASCOPY_MT5_LOGIN={json.dumps(primary.get('login', ''))}\n")
    fh.write(f"DUKASCOPY_MT5_PASSWORD={json.dumps(primary.get('password', ''))}\n")
    if primary.get("server"):
        fh.write(f"DUKASCOPY_MT5_SERVER={json.dumps(primary.get('server', ''))}\n")
    fh.write(f"DUKASCOPY_MT5_EXPIRES_AT={json.dumps(primary.get('expiresAt', ''))}\n")
    fh.write(f"DUKASCOPY_MT5_REMAINING_MS={json.dumps(str(primary.get('remainingMs', 0)))}\n")

common_ini_status = "nao encontrado"
if common_ini_path.exists():
    raw_bytes = common_ini_path.read_bytes()
    encoding = "utf-8"
    bom = b""
    text = None
    for enc, enc_bom in (("utf-16le", b"\xff\xfe"), ("utf-8", b""), ("latin1", b"")):
        try:
            probe = raw_bytes
            if enc == "utf-16le" and raw_bytes.startswith(enc_bom):
                probe = raw_bytes[len(enc_bom):]
            text = probe.decode(enc)
            encoding = enc
            bom = enc_bom if raw_bytes.startswith(enc_bom) else b""
            break
        except Exception:
            continue
    if text is None:
        print(f"ERR: nao foi possivel decodificar {common_ini_path}", file=sys.stderr)
        sys.exit(1)

    mt5 = primary
    lines = text.splitlines()
    found_login = False
    found_server = False
    found_password = False
    found_keep_private = False
    found_environment = False
    for idx, line in enumerate(lines):
        if line.startswith("Login="):
            lines[idx] = f"Login={mt5.get('login', '')}"
            found_login = True
        elif line.startswith("Server="):
            lines[idx] = f"Server={mt5.get('server', '')}"
            found_server = True
        elif line.startswith("Password="):
            lines[idx] = f"Password={mt5.get('password', '')}"
            found_password = True
        elif line.startswith("KeepPrivate="):
            lines[idx] = "KeepPrivate=1"
            found_keep_private = True
        elif line.startswith("Environment="):
            lines[idx] = "Environment="
            found_environment = True

    if not found_login:
        lines.append(f"Login={mt5.get('login', '')}")
    if not found_server:
        lines.append(f"Server={mt5.get('server', '')}")
    if not found_password:
        lines.append(f"Password={mt5.get('password', '')}")
    if not found_keep_private:
        lines.append("KeepPrivate=1")
    if not found_environment:
        lines.append("Environment=")

    new_text = "\r\n".join(lines) + "\r\n"
    encoded = new_text.encode(encoding)
    if encoding == "utf-16le" and bom:
        encoded = bom + encoded
    common_ini_path.write_bytes(encoded)
    common_ini_status = "atualizado"

print("[dockermt] Dukascopy sincronizado.")
print(f"state_file   : {state_path}")
print(f"env_file     : {env_path}")
print(f"common_ini   : {common_ini_path} ({common_ini_status})")
print(f"primary_kind : mt5")
print(f"mt5_login    : {primary.get('login', '-')}")
print(f"mt5_server   : {primary.get('server', '-') or '-'}")
print(f"mt5_expira   : {primary.get('expiresAt', '-')}")
PY
}

snapshot_select() {
