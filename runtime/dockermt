install_host_bash_function() {
  cat <<'EOF'
dockermt() {
  __dockermt_exists() {
    local cname="${1:-}"
    [ -n "$cname" ] || return 1
    docker inspect "$cname" >/dev/null 2>&1
  }

  __dockermt_label() {
    local cname="${1:-}" key="${2:-}"
    [ -n "$cname" ] || return 0
    [ -n "$key" ] || return 0
    docker inspect --format "{{index .Config.Labels \"$key\"}}" "$cname" 2>/dev/null | sed 's/^<no value>$//'
  }

  __dockermt_sanitize_key() {
    local raw="${1:-}"
    raw="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]')"
    raw="$(printf '%s' "$raw" | sed 's/[^a-z0-9._-]/-/g; s/^-*//; s/-*$//; s/--*/-/g')"
    printf '%s\n' "$raw"
  }

  __dockermt_find_first_by_label() {
    local key="${1:-}" value="${2:-}" name=""
    [ -n "$key" ] || return 1
    [ -n "$value" ] || return 1
    name="$(docker ps --filter "label=${key}=${value}" --format '{{.Names}}' 2>/dev/null | head -n 1)"
    [ -n "$name" ] || return 1
    printf '%s\n' "$name"
  }

  __dockermt_find_instance_by_name() {
    local iname="${1:-}" name=""
    [ -n "$iname" ] || return 1
    name="$(docker ps \
      --filter "label=dockermt.role=instance" \
      --filter "label=dockermt.instance.name=${iname}" \
      --format '{{.Names}}' 2>/dev/null | head -n 1)"
    [ -n "$name" ] || return 1
    printf '%s\n' "$name"
  }

  __dockermt_resolve_named() {
    local raw="${1:-}" safe="" by_label=""
    [ -n "$raw" ] || return 1
    if __dockermt_exists "$raw"; then
      printf '%s\n' "$raw"
      return 0
    fi
    safe="$(__dockermt_sanitize_key "$raw")"
    if [ -n "$safe" ]; then
      by_label="$(__dockermt_find_instance_by_name "$safe" 2>/dev/null || true)"
      if [ -n "$by_label" ]; then
        printf '%s\n' "$by_label"
        return 0
      fi
    fi
    if [ -n "$safe" ] && __dockermt_exists "dockermt-$safe"; then
      printf 'dockermt-%s\n' "$safe"
      return 0
    fi
    return 1
  }

  __dockermt_resolve_central() {
    local cname
    if [ -n "${DOCKERMT_CENTRAL_NAME:-}" ] && __dockermt_exists "$DOCKERMT_CENTRAL_NAME"; then
      printf '%s\n' "$DOCKERMT_CENTRAL_NAME"
      return 0
    fi
    cname="$(__dockermt_find_first_by_label "dockermt.role" "central" 2>/dev/null || true)"
    if [ -n "$cname" ]; then
      printf '%s\n' "$cname"
      return 0
    fi
    cname="$(__dockermt_find_first_by_label "dockermt.central" "1" 2>/dev/null || true)"
    if [ -n "$cname" ]; then
      printf '%s\n' "$cname"
      return 0
    fi
    cname="$(docker ps --format '{{.Names}} {{.Labels}}' 2>/dev/null | awk '$1 ~ /^dockermt/ && $0 !~ /dockermt.runtime=1/ {print $1; exit}')"
    if [ -n "$cname" ]; then
      printf '%s\n' "$cname"
      return 0
    fi
    cname="$(docker ps --filter 'label=dockermt.runtime=1' --format '{{.Names}}' 2>/dev/null | head -n 1)"
    if [ -n "$cname" ]; then
      local parent_label=""
      parent_label="$(__dockermt_label "$cname" "dockermt.runtime.parent")"
      if [ -n "$parent_label" ] && __dockermt_exists "$parent_label"; then
        printf '%s\n' "$parent_label"
        return 0
      fi
    fi
    if __dockermt_exists "dockermt"; then
      printf 'dockermt\n'
      return 0
    fi
    return 1
  }

  __dockermt_target_file() {
    printf '%s\n' "${HOME}/.dockermt/host-target"
  }

  __dockermt_pick_display() {
    local resolved="${DOCKERMT_APP_DISPLAY:-${DISPLAY:-}}"
    if [ -z "$resolved" ] && [ -r /etc/resolv.conf ]; then
      local ns=""
      ns="$(awk '/^nameserver[[:space:]]+/ {print $2; exit}' /etc/resolv.conf 2>/dev/null || true)"
      if [ -n "$ns" ]; then
        resolved="${ns}:0"
      fi
    fi
    printf '%s\n' "$resolved"
  }

  __dockermt_load_target() {
    local target_file loaded=""
    target_file="$(__dockermt_target_file)"
    if [ -z "${DOCKERMT_CONTAINER_NAME:-}" ] && [ -r "$target_file" ]; then
      loaded="$(head -n 1 "$target_file" 2>/dev/null | tr -d '\r\n')"
      [ -n "$loaded" ] && DOCKERMT_CONTAINER_NAME="$loaded"
    fi
  }

  __dockermt_save_target() {
    local target_name="${1:-}" target_file=""
    [ -n "$target_name" ] || return 1
    target_file="$(__dockermt_target_file)"
    mkdir -p "$(dirname "$target_file")"
    printf '%s\n' "$target_name" > "$target_file"
  }

  __dockermt_select_target() {
    local key="${1:-}" resolved=""
    [ -n "$key" ] || return 1
    if [ "$key" = "central" ]; then
      resolved="$(__dockermt_resolve_central)"
    else
      resolved="$(__dockermt_resolve_named "$key")"
    fi
    [ -n "$resolved" ] || return 1
    export DOCKERMT_CONTAINER_NAME="$resolved"
    __dockermt_save_target "$resolved" >/dev/null 2>&1 || true
    printf '[dockermt] alvo padrao: %s\n' "$resolved"
    return 0
  }

  local first="${1:-}"
  if [[ "$first" == @* ]]; then
    local target_key="${first#@}"
    [ -n "$target_key" ] || { echo "ERR: alvo vazio em '@'." >&2; return 1; }
    if [ "$#" -eq 1 ]; then
      __dockermt_select_target "$target_key" || {
        echo "ERR: alvo nao localizado: @$target_key" >&2
        return 1
      }
      return 0
    fi
    if [ "$target_key" = "central" ]; then
      __dockermt_select_target "central" || {
        echo "ERR: runtime central nao localizado." >&2
        return 1
      }
      shift || true
    fi
  fi

  __dockermt_load_target
  local target_container="${DOCKERMT_CONTAINER_NAME:-}"
  if [ -z "$target_container" ]; then
    target_container="$(__dockermt_resolve_central 2>/dev/null || true)"
    [ -n "$target_container" ] || target_container="dockermt"
    export DOCKERMT_CONTAINER_NAME="$target_container"
  fi

  if ! __dockermt_exists "$target_container"; then
    echo "ERR: container alvo nao encontrado: $target_container" >&2
    return 1
  fi

  local exec_mode=(-i)
  local app_display=""
  if [ -t 0 ] && [ -t 1 ]; then
    exec_mode=(-it)
  fi
  app_display="$(__dockermt_pick_display)"
  docker exec \
    "${exec_mode[@]}" \
    -e "DOCKERMT_CONTAINER_NAME=${target_container}" \
    -e "DOCKERMT_APP_DISPLAY=${app_display}" \
    -e "DOCKERMT_FORCE_COLOR=1" \
    -e "CLICOLOR_FORCE=1" \
    -e "COLUMNS=${COLUMNS:-120}" \
    -e "LINES=${LINES:-40}" \
    "${target_container}" /usr/local/bin/dockermt "$@"
}
EOF
}

