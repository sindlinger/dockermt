runtime_install() {
  _print_cli_banner
  local mode="script"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      script|print|help|-h|--help)
        mode="$1"
        ;;
      *)
        echo "ERR: argumento inesperado em 'dockermt install': $1" >&2
        return 1
        ;;
    esac
    shift || true
  done
  case "$mode" in
    script|"")
      local out env_file compose_file readme_file workspace_volume
      ensure_factory_workspace_volume
      workspace_volume="$DOCKERMT_WORKSPACE_FACTORY_VOLUME"
      out="$(write_install_host_script)"
      env_file="$(write_install_env_file "$workspace_volume")"
      compose_file="$(write_install_compose_file)"
      readme_file="$(write_install_readme_file "$workspace_volume")"
      printf 'install.compose: %s\n' "$compose_file"
      printf 'install.env: %s\n' "$env_file"
      printf 'install.script: %s\n' "$out"
      printf 'install.readme: %s\n' "$readme_file"
      printf 'install.workspace-factory: %s\n' "$workspace_volume"
      printf 'install.next.1: docker cp dockermt:/config/dockermt ./dockermt-bootstrap\n'
      printf 'install.next.2: cd dockermt-bootstrap\n'
      printf 'install.next.3: docker compose up -d\n'
      printf 'install.next.4: cat install-host.sh\n'
